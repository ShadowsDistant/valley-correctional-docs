# Replace the domain below if you deploy under a different hostname.
# Caddy automatically obtains and renews a Let's Encrypt certificate.
docs.valleycorrectional.xyz {
	encode gzip zstd
	reverse_proxy app:3000
}

# Staff dashboard on its own subdomain (same app; it detects the host and serves
# /dashboard at the root). Add a DNS record for `dashboard` pointing to this host.
dashboard.valleycorrectional.xyz {
	encode gzip zstd
	reverse_proxy app:3000
}

