# ---------------------------------------------------------------------------
# Valley Correctional Facility Docs — environment configuration
# Copy this file to `.env` and edit the values before first launch.
# ---------------------------------------------------------------------------

# Port the Node app listens on (Caddy proxies to this internally).
PORT=3000

# Public URL of the site (used for canonical links & cookie security).
SITE_URL=https://docs.valleycorrectional.xyz

# Set to "production" on the server. Enables secure cookies + hides errors.
NODE_ENV=production

# Long random string used to sign session cookies. GENERATE YOUR OWN:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# The first administrator account, created automatically on first boot.
# After first login, change this password from Admin → Staff, then you may
# remove ADMIN_PASSWORD from this file.
ADMIN_USERNAME=shadowsdistant
ADMIN_PASSWORD=change-me-on-first-login

# Trust the X-Forwarded-* headers from the Caddy/Nginx reverse proxy so that
# secure cookies and real client IPs work. Keep 1 behind a single proxy.
TRUST_PROXY=1
