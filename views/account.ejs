<%- include('partials/head') %>
<%- include('partials/topbar') %>
<% var infr = (typeof myInfractions !== 'undefined') ? myInfractions : []; var ranks = (typeof rankLabels !== 'undefined') ? rankLabels : []; %>
<div class="account-wrap">
  <div class="account-card">

    <!-- Profile hero -->
    <header class="profile-hero" id="robloxAccount" data-user="<%= user.username %>">
      <div class="profile-avatar" data-rbx-avatar="<%= user.username %>"><%= user.username.slice(0,1).toUpperCase() %></div>
      <div class="profile-id">
        <div class="profile-name"><strong><%= user.username %></strong></div>
        <div class="profile-sub muted small"><span class="rbx-status">Loading…</span></div>
        <div class="profile-badges">
          <span class="badge cap <%= user.role==='admin'?'badge-internal':'' %>"><%= user.role %></span>
          <% ranks.forEach(function(rl){ %><span class="badge badge-internal"><%= rl %></span><% }); %>
        </div>
      </div>
      <% if (typeof myPoints !== 'undefined') { %>
        <div class="profile-points">
          <span class="pill pill-<%= myPoints>=6?'red':(myPoints>=3?'amber':'grey') %>"><%= myPoints %></span>
          <span class="muted small">Disciplinary Points · 6mo</span>
        </div>
      <% } %>
    </header>

    <% if (user.terminated) { %>
      <div class="auth-error"><%- icon('danger') %> <span>This account has been <strong>terminated</strong>.</span></div>
    <% } else if (user.suspended) { %>
      <div class="auth-error"><%- icon('danger') %> <span>Your account is <strong>suspended</strong><% if (user.suspended_until) { %> — access returns <strong><time data-time="<%= user.suspended_until %>" data-time-format="datetime"><%= user.suspended_until.slice(0,10) %></time></strong><% } else { %> indefinitely — contact an administrator<% } %>.</span></div>
    <% } %>
    <% if (typeof done !== 'undefined' && done) { %>
      <div class="account-ok"><%- icon('check') %> <span>Your password has been updated.</span></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="auth-error"><%- icon('danger') %> <span><%= error %></span></div>
    <% } %>

    <div class="profile-grid">
      <div class="profile-col">
      <div class="profile-col-label"><%- icon('scale') %> Record</div>
      <!-- Disciplinary record -->
      <section class="panel account-panel account-record">
        <div class="panel-head"><h2>Disciplinary record</h2><span class="badge <%= (typeof myPoints!=='undefined'&&myPoints>=3)?'badge-danger':'' %>"><%= infr.length %> active</span></div>
        <% if (!infr.length) { %>
          <div class="record-empty"><%- icon('check') %><p>No active infractions on record. Keep it up.</p></div>
        <% } else { %>
          <p class="muted small" style="margin:-4px 0 12px">Evidence and case details are confidential to the issuing division.</p>
          <div class="table-scroll"><table class="table">
            <thead><tr><th>Type</th><th class="num">Pts</th><th>Reason</th><th>Outcome</th><th>When</th></tr></thead>
            <tbody>
              <% infr.forEach(function(f){ %><tr>
                <td class="small"><%= f.type %></td>
                <td class="num mono"><%= f.points %></td>
                <td class="small"><%= f.reason %></td>
                <td class="small"><% if (f.outcome && f.outcome!=='No action') { %><span class="pill pill-<%= /Termination/.test(f.outcome)?'red':(/Suspension/.test(f.outcome)?'amber':'grey') %>"><%= f.outcome %></span><% } else { %>—<% } %></td>
                <td class="small nowrap"><time data-time="<%= f.created_at %>"><%= f.created_at.slice(0,10) %></time></td>
              </tr><% }); %>
            </tbody>
          </table></div>
        <% } %>
      </section>
      </div>

      <div class="profile-col">
      <div class="profile-col-label"><%- icon('shield') %> Security</div>
      <!-- Change password -->
      <section class="panel account-panel">
        <div class="panel-head"><h2>Change password</h2></div>
        <form method="post" action="/account/password" class="stack-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="field">Current password
            <input type="password" name="current" required autocomplete="current-password" />
          </label>
          <label class="field">New password
            <input type="password" name="new" minlength="8" required autocomplete="new-password" placeholder="At least 8 characters" />
          </label>
          <label class="field">Confirm new password
            <input type="password" name="confirm" minlength="8" required autocomplete="new-password" />
          </label>
          <div><button class="btn btn-solid" type="submit"><%- icon('lock') %> Update password</button></div>
        </form>
      </section>

      <!-- Passkeys (WebAuthn 2FA) -->
      <section class="panel account-panel" id="passkeySection">
        <div class="panel-head"><h2><%- icon('key') %> Passkeys</h2><% if (typeof passkeys !== 'undefined' && passkeys.length) { %><span class="badge badge-internal">2FA on</span><% } %></div>
        <p class="muted small pk-intro">Add a passkey (fingerprint, face, PIN, or a hardware key) as a second step at login. Once you have one, your password alone won't be enough to sign in — a stolen password can't get in without your device.</p>
        <ul class="pk-list" id="pkList">
          <% (typeof passkeys !== 'undefined' ? passkeys : []).forEach(function (p) { %>
            <li class="pk-item" data-pk="<%= p.id %>">
              <span class="pk-ico"><%- icon('key') %></span>
              <div class="pk-meta">
                <strong><%= p.name %></strong>
                <span class="muted small">Added <time data-time="<%= p.created_at %>"><%= p.created_at.slice(0,10) %></time><% if (p.last_used) { %> · last used <time data-time="<%= p.last_used %>"><%= p.last_used.slice(0,10) %></time><% } %></span>
              </div>
              <form method="post" action="/account/passkey/<%= p.id %>/remove" class="inline pk-remove" data-confirm="Remove this passkey? If it's your last one, your account drops back to password-only." data-confirm-title="Remove passkey" data-confirm-ok="Remove">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button class="btn btn-ghost btn-sm" type="submit"><%- icon('trash') %></button>
              </form>
            </li>
          <% }); %>
        </ul>
        <p class="pk-empty muted small"<%= (typeof passkeys !== 'undefined' && passkeys.length) ? ' hidden' : '' %>>No passkeys yet — you sign in with your password only.</p>
        <div class="pk-add-row">
          <input type="text" id="pkName" maxlength="40" placeholder="Name this device (e.g. My laptop)" autocomplete="off" />
          <button class="btn btn-solid" type="button" id="pkAdd"><%- icon('plus') %> Add a passkey</button>
        </div>
        <div class="pk-msg" id="pkAddMsg"></div>
      </section>
      </div>
    </div>
  </div>
</div>
<script src="/assets/js/passkey.js?v=<%= assetVersion %>"></script>
<script>
(function () {
  var box = document.getElementById('robloxAccount'); if (!box) return;
  var name = box.getAttribute('data-user');
  fetch('/api/roblox/' + encodeURIComponent(name)).then(function (r) { return r.json(); }).then(function (d) {
    var st = box.querySelector('.rbx-status');
    if (!d.ok) { st.textContent = 'No linked account'; return; }
    st.innerHTML = '<strong>' + d.displayName + '</strong> <span class="muted">@' + d.name + '</span> · <a href="https://www.roblox.com/users/' + d.id + '/profile" target="_blank" rel="noopener">profile ↗</a>';
  }).catch(function () {});
})();

// ---- passkey management ----
(function () {
  var add = document.getElementById('pkAdd'); if (!add) return;
  var msg = document.getElementById('pkAddMsg'), list = document.getElementById('pkList');
  var empty = document.querySelector('.pk-empty'), nameIn = document.getElementById('pkName');
  var section = document.getElementById('passkeySection');
  if (!window.vcfPasskey || !window.vcfPasskey.supported) {
    add.disabled = true; msg.className = 'pk-msg err';
    msg.textContent = 'This browser does not support passkeys.';
    return;
  }
  function esc(s){ return String(s==null?'':s).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];}); }
  function render(list_) {
    // read the CSRF token from any form on the page — on the first passkey the
    // section has no rows yet, so it wouldn't have its own token.
    var tok = document.querySelector('input[name="_csrf"]');
    var csrf = tok ? tok.value : '';
    list.innerHTML = list_.map(function (p) {
      return '<li class="pk-item" data-pk="' + p.id + '"><span class="pk-ico"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="8" cy="15" r="4"/><path d="M10.8 12.2 20 3M17 6l3 3M15 8l2 2"/></svg></span>' +
        '<div class="pk-meta"><strong>' + esc(p.name) + '</strong><span class="muted small">Added ' + (p.created_at||'').slice(0,10) + '</span></div>' +
        '<form method="post" action="/account/passkey/' + p.id + '/remove" class="inline pk-remove" data-confirm="Remove this passkey? If it\'s your last one, your account drops back to password-only." data-confirm-title="Remove passkey" data-confirm-ok="Remove">' +
        '<input type="hidden" name="_csrf" value="' + csrf + '" /><button class="btn btn-ghost btn-sm" type="submit"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M8 6V4h8v2M6 6l1 14h10l1-14"/></svg></button></form></li>';
    }).join('');
    if (empty) empty.hidden = list_.length > 0;
    if (window.fillTimes) window.fillTimes();
  }
  add.addEventListener('click', function () {
    add.disabled = true; msg.className = 'pk-msg'; msg.textContent = 'Follow your device prompt…';
    window.vcfPasskey.register(nameIn.value.trim()).then(function (d) {
      add.disabled = false;
      if (!d || !d.ok) { msg.className = 'pk-msg err'; msg.textContent = (d && d.error) || 'Could not add passkey.'; return; }
      nameIn.value = ''; msg.className = 'pk-msg ok'; msg.textContent = 'Passkey added. It will be required at your next login.';
      render(d.passkeys || []);
    }).catch(function (e) {
      add.disabled = false; msg.className = 'pk-msg err';
      msg.textContent = (e && e.name === 'NotAllowedError') ? 'Prompt dismissed — nothing added.' : ((e && e.message) || 'Could not add passkey.');
    });
  });
  // Removal uses the native form POST via the shared confirm modal (data-confirm),
  // which redirects back to /account with the list refreshed.
})();
</script>
<%- include('partials/foot') %>
