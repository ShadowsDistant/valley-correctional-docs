<%- include('partials/head') %>
<%- include('partials/topbar') %>
<div class="layout">
  <%- include('partials/sidebar') %>
  <main class="content">
    <article class="doc <%= page.internal ? 'protected' : '' %>"<% if (page.internal) { %> data-protected="1" data-user="<%= user ? user.username : '' %>"<% } %>>
      <div class="doc-breadcrumb">
        <% if (page.group_name) { %><span><%= page.group_name %></span><span class="sep">/</span><% } %>
        <span class="crumb-current"><%= page.title %></span>
      </div>

      <div class="doc-titlerow">
        <h1 class="doc-title"><%= page.title %></h1>
        <% if (typeof canEditThis !== 'undefined' && canEditThis) { %>
          <a class="btn btn-ghost btn-edit" href="/admin/edit?slug=<%= encodeURIComponent(page.slug) %>"><%- icon('edit') %> Edit this page</a>
        <% } %>
      </div>
      <% if (page.description) { %><p class="doc-lead"><%= page.description %></p><% } %>

      <% if (page.internal) { %>
        <div class="protect-note"><%- icon('lock') %> Confidential staff document — copying, printing, and redistribution are disabled and monitored.</div>
      <% } %>

      <div class="markdown"><%- html %></div>

      <div class="doc-meta">
        Last updated <%= page.updated_at %><% if (page.updated_by) { %> · by <%= page.updated_by %><% } %>
      </div>

      <nav class="pager">
        <% if (prev) { %>
          <a class="pager-link prev" href="/<%= prev.slug %>"><span>← Previous</span><strong><%= prev.title %></strong></a>
        <% } else { %><span></span><% } %>
        <% if (next) { %>
          <a class="pager-link next" href="/<%= next.slug %>"><span>Next →</span><strong><%= next.title %></strong></a>
        <% } %>
      </nav>
    </article>

    <aside class="toc">
      <% if (toc && toc.length) { %>
        <div class="toc-title">On this page</div>
        <ul>
          <% toc.forEach(function (h) { %>
            <li class="toc-l<%= h.level %>"><a href="#<%= h.id %>"><%= h.text %></a></li>
          <% }); %>
        </ul>
      <% } %>
    </aside>
  </main>
</div>
<% if (page.internal) { %><script src="/assets/js/protect.js"></script><% } %>
<%- include('partials/foot') %>
