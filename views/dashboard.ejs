<%- include('partials/head') %>
<%- include('partials/topbar') %>
<div class="dash-wrap">
  <div class="dash-head">
    <div>
      <h1 class="admin-h1">Staff Dashboard <span class="beta-tag">Beta</span></h1>
      <p class="admin-sub">
        Logged in as <strong><%= user.username %></strong><% if (rankLabel) { %> · <span class="badge badge-internal"><%= rankLabel %></span><% } %>
      </p>
    </div>
    <a class="btn btn-ghost btn-sm" href="/home"><%- icon('external') %> Docs</a>
  </div>

  <% if (needsApproval) { %>
    <div class="dash-notice"><%- icon('info') %> <span>Your rank is <strong>junior</strong> — logs you submit are held as <strong>pending</strong> until a senior approves them. They do not take effect until then.</span></div>
  <% } %>
  <% if (typeof saved === 'undefined') { var saved = null; } %>

  <div class="stat-grid dash-stats">
    <% if (canModerate) { %>
      <div class="stat-card"><span class="stat-num"><%= stats.punTotal %></span><span class="stat-label">Active punishments</span></div>
      <div class="stat-card"><span class="stat-num"><%= stats.pun7 %></span><span class="stat-label">Punishments · 7d</span></div>
    <% } %>
    <% if (canSID) { %>
      <div class="stat-card"><span class="stat-num"><%= stats.infTotal %></span><span class="stat-label">Active infractions</span></div>
      <div class="stat-card"><span class="stat-num"><%= stats.inf7 %></span><span class="stat-label">Infractions · 7d</span></div>
    <% } %>
    <% if (canApprove) { %>
      <div class="stat-card <%= stats.pending ? 'stat-alert' : '' %>"><span class="stat-num"><%= stats.pending %></span><span class="stat-label">Pending approvals</span></div>
    <% } %>
  </div>

  <div class="dash-tabs" id="dashTabs">
    <% if (canModerate) { %><button type="button" class="dash-tab active" data-tab="mod"><%- icon('shield') %> Moderation</button><% } %>
    <% if (canSID) { %><button type="button" class="dash-tab <%= canModerate ? '' : 'active' %>" data-tab="sid"><%- icon('eye') %> SID</button><% } %>
    <% if (canApprove) { %><button type="button" class="dash-tab" data-tab="pending">Pending <% if (stats.pending) { %><span class="tab-count"><%= stats.pending %></span><% } %></button><% } %>
  </div>

  <form method="get" action="/dashboard" class="dash-search">
    <%- icon('search') %>
    <input type="text" name="q" value="<%= q %>" placeholder="Search logs…" autocomplete="off" />
    <button class="btn btn-solid btn-sm" type="submit">Search</button>
    <% if (q) { %><a class="btn btn-ghost btn-sm" href="/dashboard">Clear</a><% } %>
  </form>

  <!-- MODERATION -->
  <% if (canModerate) { %>
  <section class="dash-tabpane" data-pane="mod">
    <div class="panel dash-panel">
      <div class="panel-head"><h2><%- icon('shield') %> Log a punishment</h2></div>
      <form method="post" action="/dashboard/punishment" class="dash-form" data-roblox="1">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label class="field">Quick preset
          <select class="preset-sel" data-target="pun"><option value="">— Custom —</option><% punishPresets.forEach(function(p){ %><option value="<%= p.type %>" data-reason="<%= p.reason %>"><%= p.label %> → <%= p.type %></option><% }); %></select>
        </label>
        <div class="field-grid">
          <label class="field">Roblox username
            <span class="roblox-input"><input type="text" name="roblox_user" required autocomplete="off" placeholder="Builderman" /><button type="button" class="btn btn-ghost btn-sm rbx-lookup">Look up</button></span>
          </label>
          <label class="field">Roblox ID <input type="text" name="roblox_id" autocomplete="off" placeholder="auto-filled" /></label>
          <label class="field">Type
            <select name="type" id="pun-type"><% punishTypes.forEach(function(t){ %><option value="<%= t %>"><%= t %></option><% }); %></select>
          </label>
          <label class="field">Duration <small>(if temp)</small><input type="text" name="duration" placeholder="7 days" autocomplete="off" /></label>
        </div>
        <div class="rbx-card" hidden></div>
        <label class="field">Reason<input type="text" name="reason" id="pun-reason" required placeholder="What happened" autocomplete="off" /></label>
        <div class="evidence-row">
          <label class="field">Evidence <small>(link or file)</small><input type="text" name="evidence" class="ev-input" placeholder="https://… or attach a file" autocomplete="off" /></label>
          <div class="ev-upload"><input type="file" class="ev-file" accept="image/png,image/jpeg,image/gif,image/webp,application/pdf" hidden /><button type="button" class="btn btn-ghost btn-sm ev-attach"><%- icon('files') %> Attach</button><span class="ev-status muted small"></span></div>
        </div>
        <div><button class="btn btn-solid" type="submit"><%- icon('plus') %> <%= needsApproval ? 'Submit for approval' : 'Log punishment' %></button></div>
      </form>
    </div>

    <div class="panel dash-panel">
      <div class="panel-head"><h2>Punishment history</h2><span class="muted small"><%= punishments.length %> shown</span></div>
      <div class="table-scroll dash-list">
        <table class="table">
          <thead><tr><th>Roblox user</th><th>Type</th><th>Reason</th><th>By</th><th>When</th><th></th></tr></thead>
          <tbody>
            <% if (!punishments.length) { %><tr><td colspan="6" class="muted" style="padding:16px">No active punishments<%= q ? ' for “'+q+'”' : '' %>.</td></tr><% } %>
            <% punishments.forEach(function(p){ %>
              <tr class="<%= p.voided ? 'row-void' : '' %>">
                <td class="mono small"><%= p.roblox_user %><% if (p.roblox_id) { %> <span class="muted">#<%= p.roblox_id %></span><% } %></td>
                <td><span class="pill pill-<%= p.type.toLowerCase().indexOf('ban')>=0 ? 'red' : (p.type==='Note'?'grey':'amber') %>"><%= p.type %></span><% if (p.duration) { %> <span class="muted small"><%= p.duration %></span><% } %></td>
                <td class="small"><%= p.reason %><% if (p.evidence) { %> <a href="<%= p.evidence %>" target="_blank" rel="noopener" class="ev-link">evidence</a><% } %></td>
                <td class="small"><%= p.moderator %></td>
                <td class="small nowrap"><time data-time="<%= p.created_at %>"><%= p.created_at.slice(0,16) %></time></td>
                <td><% if (!p.voided) { %><form method="post" action="/dashboard/punishment/void" class="inline" data-confirm="Void this punishment against <%= p.roblox_user %>?" data-confirm-title="Void punishment" data-confirm-ok="Void"><input type="hidden" name="_csrf" value="<%= csrfToken %>"/><input type="hidden" name="id" value="<%= p.id %>"/><button class="btn btn-ghost btn-sm" type="submit">Void</button></form><% } else { %><span class="badge">voided</span><% } %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
  <% } %>

  <!-- SID -->
  <% if (canSID) { %>
  <section class="dash-tabpane" data-pane="sid" <%= canModerate ? 'hidden' : '' %>>
    <div class="panel dash-panel">
      <div class="panel-head"><h2><%- icon('eye') %> Issue an infraction</h2></div>
      <form method="post" action="/dashboard/infraction" class="dash-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label class="field">Quick preset
          <select class="preset-sel" data-target="inf"><option value="">— Custom —</option><% infractionPresets.forEach(function(p){ %><option value="<%= p.type %>" data-reason="<%= p.reason %>"><%= p.label %> → <%= p.type %></option><% }); %></select>
        </label>
        <div class="field-grid">
          <label class="field">Staff member
            <select name="staff_user" required><option value="">— Select staff —</option><% staffList.forEach(function(s){ %><option value="<%= s %>"><%= s %></option><% }); %></select>
          </label>
          <label class="field">Type
            <select name="type" id="inf-type"><% infractionTypes.forEach(function(t){ %><option value="<%= t %>"><%= t %></option><% }); %></select>
          </label>
        </div>
        <label class="field">Reason<input type="text" name="reason" id="inf-reason" required placeholder="What happened" autocomplete="off" /></label>
        <div class="evidence-row">
          <label class="field">Evidence <small>(link or file)</small><input type="text" name="evidence" class="ev-input" placeholder="https://… or attach a file" autocomplete="off" /></label>
          <div class="ev-upload"><input type="file" class="ev-file" accept="image/png,image/jpeg,image/gif,image/webp,application/pdf" hidden /><button type="button" class="btn btn-ghost btn-sm ev-attach"><%- icon('files') %> Attach</button><span class="ev-status muted small"></span></div>
        </div>
        <div><button class="btn btn-solid" type="submit"><%- icon('plus') %> <%= needsApproval ? 'Submit for approval' : 'Issue infraction' %></button></div>
      </form>
    </div>

    <div class="panel dash-panel">
      <div class="panel-head"><h2>Infraction history</h2><span class="muted small"><%= infractions.length %> shown</span></div>
      <div class="table-scroll dash-list">
        <table class="table">
          <thead><tr><th>Staff</th><th>Type</th><th>Reason</th><th>By</th><th>When</th><th></th></tr></thead>
          <tbody>
            <% if (!infractions.length) { %><tr><td colspan="6" class="muted" style="padding:16px">No active infractions<%= q ? ' for “'+q+'”' : '' %>.</td></tr><% } %>
            <% infractions.forEach(function(f){ %>
              <tr class="<%= f.voided ? 'row-void' : '' %>">
                <td class="small"><strong><%= f.staff_user %></strong></td>
                <td><span class="pill pill-<%= (f.type==='Termination'||f.type==='Demotion'||f.type==='Suspension')?'red':(f.type==='Strike'?'amber':'grey') %>"><%= f.type %></span></td>
                <td class="small"><%= f.reason %><% if (f.evidence) { %> <a href="<%= f.evidence %>" target="_blank" rel="noopener" class="ev-link">evidence</a><% } %></td>
                <td class="small"><%= f.issued_by %></td>
                <td class="small nowrap"><time data-time="<%= f.created_at %>"><%= f.created_at.slice(0,16) %></time></td>
                <td><% if (!f.voided) { %><form method="post" action="/dashboard/infraction/void" class="inline" data-confirm="Void this infraction against <%= f.staff_user %>?" data-confirm-title="Void infraction" data-confirm-ok="Void"><input type="hidden" name="_csrf" value="<%= csrfToken %>"/><input type="hidden" name="id" value="<%= f.id %>"/><button class="btn btn-ghost btn-sm" type="submit">Void</button></form><% } else { %><span class="badge">voided</span><% } %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
  <% } %>

  <!-- PENDING APPROVALS -->
  <% if (canApprove) { %>
  <section class="dash-tabpane" data-pane="pending" hidden>
    <div class="panel dash-panel">
      <div class="panel-head"><h2>Pending approval</h2><span class="muted small"><%= stats.pending %> awaiting review</span></div>
      <% if (!pendingPun.length && !pendingInf.length) { %>
        <p class="muted" style="padding:8px 0">Nothing pending. Junior staff submissions will appear here for review.</p>
      <% } %>
      <% pendingPun.forEach(function(p){ %>
        <div class="pending-card">
          <div class="pending-info"><span class="pill pill-<%= p.type.toLowerCase().indexOf('ban')>=0?'red':'amber' %>"><%= p.type %></span> <strong><%= p.roblox_user %></strong> <span class="muted small">by <%= p.moderator %> · <time data-time="<%= p.created_at %>"><%= p.created_at.slice(0,16) %></time></span><div class="small"><%= p.reason %><% if (p.evidence) { %> <a href="<%= p.evidence %>" target="_blank" rel="noopener" class="ev-link">evidence</a><% } %></div></div>
          <div class="pending-actions">
            <form method="post" action="/dashboard/punishment/review" class="inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>"/><input type="hidden" name="id" value="<%= p.id %>"/><input type="hidden" name="decision" value="approve"/><button class="btn btn-solid btn-sm" type="submit">Approve</button></form>
            <form method="post" action="/dashboard/punishment/review" class="inline" data-confirm="Reject and delete this pending punishment?" data-confirm-title="Reject" data-confirm-ok="Reject"><input type="hidden" name="_csrf" value="<%= csrfToken %>"/><input type="hidden" name="id" value="<%= p.id %>"/><input type="hidden" name="decision" value="reject"/><button class="btn btn-ghost btn-sm danger" type="submit">Reject</button></form>
          </div>
        </div>
      <% }); %>
      <% pendingInf.forEach(function(f){ %>
        <div class="pending-card">
          <div class="pending-info"><span class="pill pill-<%= (f.type==='Termination'||f.type==='Demotion'||f.type==='Suspension')?'red':'grey' %>"><%= f.type %></span> <strong><%= f.staff_user %></strong> <span class="muted small">by <%= f.issued_by %> · <time data-time="<%= f.created_at %>"><%= f.created_at.slice(0,16) %></time></span><div class="small"><%= f.reason %><% if (f.evidence) { %> <a href="<%= f.evidence %>" target="_blank" rel="noopener" class="ev-link">evidence</a><% } %></div></div>
          <div class="pending-actions">
            <form method="post" action="/dashboard/infraction/review" class="inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>"/><input type="hidden" name="id" value="<%= f.id %>"/><input type="hidden" name="decision" value="approve"/><button class="btn btn-solid btn-sm" type="submit">Approve</button></form>
            <form method="post" action="/dashboard/infraction/review" class="inline" data-confirm="Reject and delete this pending infraction?" data-confirm-title="Reject" data-confirm-ok="Reject"><input type="hidden" name="_csrf" value="<%= csrfToken %>"/><input type="hidden" name="id" value="<%= f.id %>"/><input type="hidden" name="decision" value="reject"/><button class="btn btn-ghost btn-sm danger" type="submit">Reject</button></form>
          </div>
        </div>
      <% }); %>
    </div>
  </section>
  <% } %>

  <p class="muted small dash-foot"><%- icon('info') %> This dashboard is in <strong>beta</strong>. Every action is logged and auditable.</p>
</div>

<script>
(function () {
  // tabs
  var tabs = document.getElementById('dashTabs');
  if (tabs) tabs.addEventListener('click', function (e) {
    var b = e.target.closest('.dash-tab'); if (!b) return;
    tabs.querySelectorAll('.dash-tab').forEach(function (t) { t.classList.toggle('active', t === b); });
    document.querySelectorAll('.dash-tabpane').forEach(function (p) { p.hidden = p.getAttribute('data-pane') !== b.getAttribute('data-tab'); });
  });
  // presets → fill type + reason
  document.querySelectorAll('.preset-sel').forEach(function (sel) {
    sel.addEventListener('change', function () {
      var t = sel.getAttribute('data-target');
      var opt = sel.options[sel.selectedIndex];
      if (!sel.value) return;
      var typeEl = document.getElementById(t + '-type'), reasonEl = document.getElementById(t + '-reason');
      if (typeEl) { typeEl.value = sel.value; typeEl.dispatchEvent(new Event('change', { bubbles: true })); }
      if (reasonEl && opt.getAttribute('data-reason')) reasonEl.value = opt.getAttribute('data-reason');
    });
  });
  // Roblox lookup
  document.querySelectorAll('.rbx-lookup').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var form = btn.closest('form');
      var nameEl = form.querySelector('[name=roblox_user]'), idEl = form.querySelector('[name=roblox_id]');
      var card = form.querySelector('.rbx-card');
      var name = (nameEl.value || '').trim(); if (!name) return;
      btn.textContent = '…';
      fetch('/api/roblox/' + encodeURIComponent(name)).then(function (r) { return r.json(); }).then(function (d) {
        btn.textContent = 'Look up';
        if (!d.ok) { card.hidden = false; card.innerHTML = '<span class="muted">No Roblox user found for “' + name + '”.</span>'; return; }
        if (idEl) idEl.value = d.id;
        nameEl.value = d.name;
        card.hidden = false;
        card.innerHTML = (d.avatar ? '<img src="' + d.avatar + '" alt="" width="40" height="40" />' : '')
          + '<div><strong>' + d.displayName + '</strong> <span class="muted">@' + d.name + '</span><br><span class="muted small">ID ' + d.id + '</span></div>';
      }).catch(function () { btn.textContent = 'Look up'; });
    });
  });
  // evidence file upload
  document.querySelectorAll('.ev-upload').forEach(function (wrap) {
    var file = wrap.querySelector('.ev-file'), btn = wrap.querySelector('.ev-attach'), status = wrap.querySelector('.ev-status');
    var input = wrap.closest('.evidence-row').querySelector('.ev-input');
    btn.addEventListener('click', function () { file.click(); });
    file.addEventListener('change', function () {
      var f = file.files[0]; if (!f) return;
      if (f.size > 4 * 1024 * 1024) { status.textContent = 'Too large (max 4 MB)'; return; }
      status.textContent = 'Uploading…';
      var reader = new FileReader();
      reader.onload = function () {
        fetch('/api/upload', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type: f.type, data: reader.result }) })
          .then(function (r) { return r.json(); }).then(function (d) {
            if (d.ok) { input.value = d.url; status.innerHTML = '<span style="color:#22c55e">Attached</span>'; }
            else status.textContent = d.error || 'Upload failed';
          }).catch(function () { status.textContent = 'Upload failed'; });
      };
      reader.readAsDataURL(f);
    });
  });
})();
</script>
<%- include('partials/foot') %>
