<aside class="sidebar admin-sidebar" id="sidebar">
  <nav class="side-nav">
    <div class="nav-group">
      <div class="nav-group-title">Overview</div>
      <ul>
        <li><a class="nav-link <%= section === 'dashboard' ? 'active' : '' %>" href="/admin"><span class="nav-ico"><%- icon('chart') %></span><span class="nav-label">Dashboard</span></a></li>
        <% if (user && user.role === 'admin') { %>
          <li><a class="nav-link <%= section === 'analytics' ? 'active' : '' %>" href="/admin/analytics"><span class="nav-ico"><%- icon('target') %></span><span class="nav-label">Analytics</span></a></li>
        <% } %>
      </ul>
    </div>

    <div class="nav-group">
      <div class="nav-group-title">Content</div>
      <ul>
        <li><a class="nav-link <%= section === 'pages' ? 'active' : '' %>" href="/admin/pages"><span class="nav-ico"><%- icon('file') %></span><span class="nav-label">Pages</span></a></li>
        <% if (user && user.role === 'admin') { %>
          <li><a class="nav-link" href="/admin/new"><span class="nav-ico"><%- icon('plus') %></span><span class="nav-label">New page</span></a></li>
          <li><a class="nav-link <%= section === 'shifts' ? 'active' : '' %>" href="/admin/shifts"><span class="nav-ico"><%- icon('calendar') %></span><span class="nav-label">Event scheduler</span></a></li>
        <% } %>
      </ul>
    </div>

    <% var showPeople = user && (user.role === 'admin' || (typeof canManageStaffNav !== 'undefined' && canManageStaffNav) || (typeof canFeedbackStaff !== 'undefined' && canFeedbackStaff)); %>
    <% if (showPeople) { %>
      <div class="nav-group">
        <div class="nav-group-title">People</div>
        <ul>
          <% if (user.role === 'admin' || (typeof canManageStaffNav !== 'undefined' && canManageStaffNav)) { %>
            <li><a class="nav-link <%= section === 'staff' ? 'active' : '' %>" href="/admin/staff"><span class="nav-ico"><%- icon('users') %></span><span class="nav-label">Staff</span></a></li>
          <% } %>
          <% if (typeof canFeedbackStaff !== 'undefined' && canFeedbackStaff) { %>
            <li><a class="nav-link <%= section === 'feedback' ? 'active' : '' %>" href="/admin/feedback"><span class="nav-ico"><%- icon('message') %></span><span class="nav-label">Feedback<% if (typeof openFeedback !== 'undefined' && openFeedback) { %> <span class="tab-count"><%= openFeedback %></span><% } %></span></a></li>
          <% } %>
          <% if (user.role === 'admin') { %>
            <li><a class="nav-link <%= section === 'policy' ? 'active' : '' %>" href="/admin/policy"><span class="nav-ico"><%- icon('scroll') %></span><span class="nav-label">Staff policy</span></a></li>
          <% } %>
        </ul>
      </div>
    <% } %>

    <% if (user && user.role === 'admin') { %>
      <div class="nav-group">
        <div class="nav-group-title">Security</div>
        <ul>
          <li><a class="nav-link <%= section === 'logs' ? 'active' : '' %>" href="/admin/logs"><span class="nav-ico"><%- icon('list') %></span><span class="nav-label">Activity log</span></a></li>
          <li><a class="nav-link <%= section === 'watermark' ? 'active' : '' %>" href="/admin/watermark-tool"><span class="nav-ico"><%- icon('search') %></span><span class="nav-label">Watermark reveal</span></a></li>
        </ul>
      </div>

      <div class="nav-group">
        <div class="nav-group-title">System</div>
        <ul>
          <li><a class="nav-link <%= section === 'system' ? 'active' : '' %>" href="/admin/system"><span class="nav-ico"><%- icon('gear') %></span><span class="nav-label">Server &amp; updates</span></a></li>
        </ul>
      </div>
    <% } %>

    <div class="nav-group">
      <div class="nav-group-title">Shortcuts</div>
      <ul>
        <li><a class="nav-link" href="/home"><span class="nav-ico"><%- icon('external') %></span><span class="nav-label">View live site</span></a></li>
      </ul>
    </div>
  </nav>
  <div class="side-foot">
    <a class="side-user" href="/account" data-tip="Your profile" data-tip-pos="top">
      <span class="side-user-av" data-rbx-avatar="<%= user.username %>"><%= (user.username || '?').slice(0,1).toUpperCase() %></span>
      <span class="side-user-meta">
        <strong class="side-user-name"><%= user.username %></strong>
        <span class="side-user-role"><%= user.role %></span>
      </span>
      <span class="side-user-go"><%- icon('external') %></span>
    </a>
  </div>
</aside>
<div class="scrim" id="scrim"></div>
