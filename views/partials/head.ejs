<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title ? title + ' · ' + siteName : siteName %></title>
  <meta name="description" content="<%= typeof page !== 'undefined' && page && page.description ? page.description : siteTagline %>" />
  <meta name="theme-color" content="#ffa200" />
  <link rel="icon" href="/assets/favicon-og.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/assets/icons.css" />
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <script>
    // Dark is the default appearance (matches the original site's strict dark theme).
    (function () {
      try {
        var t = localStorage.getItem('vcf-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    })();
  </script>
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
