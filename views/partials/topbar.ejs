<header class="topbar">
  <button class="icon-btn menu-toggle" id="menuToggle" aria-label="Toggle navigation">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>

  <a class="brand" href="/home" title="<%= siteName %>">
    <img class="brand-logo" src="/assets/logo.png" alt="<%= siteName %>" width="38" height="38" />
  </a>

  <div class="search" role="search">
    <svg class="search-ico" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="searchInput" type="text" placeholder="Search the docs..." autocomplete="off" spellcheck="false" />
    <kbd>/</kbd>
    <div id="searchResults" class="search-results" hidden></div>
  </div>

  <nav class="top-actions">
    <a class="top-link doc-tab" href="/home"><%- icon('file') %> Public Documents</a>
    <% if (user) { %><a class="top-link doc-tab" href="/internal-documents/general-staff-handbook"><%- icon('lock') %> Internal Documents</a><% } %>
    <a class="btn btn-primary discord-cta" href="<%= discord %>" target="_blank" rel="noopener"><%- icon('discord') %> Join our Discord ›</a>

    <div class="account-menu" id="accountMenu">
      <button class="account-btn" id="accountBtn" aria-haspopup="true" aria-expanded="false">
        <% if (user) { %><span class="acct-avatar" data-rbx-avatar="<%= user.username %>"><%= (user.username||'?').slice(0,1).toUpperCase() %></span><span class="acct-name"><%= user.username %></span><% } else { %><%- icon('users') %> <span class="acct-name">Account</span><% } %>
        <svg class="acct-caret" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="account-dropdown" id="accountDropdown" hidden>
        <% if (user) { %>
          <div class="acct-dd-head"><strong><%= user.username %></strong><span class="badge cap <%= user.role==='admin'?'badge-internal':'' %>"><%= user.role %></span></div>
          <% if (canEdit) { %><a href="/admin"><%- icon('chart') %> Dashboard</a><% } %>
          <% if (typeof canStaffDashboard !== 'undefined' && canStaffDashboard) { %><a href="/dashboard"><%- icon('shield') %> Staff Dashboard <span class="beta-tag sm">Beta</span></a><% } %>
          <% if (canManageShifts && !canEdit) { %><a href="/admin/shifts"><%- icon('calendar') %> Event scheduler</a><% } %>
          <% if (typeof canFeedbackStaff !== 'undefined' && canFeedbackStaff && !canEdit) { %><a href="/admin/feedback"><%- icon('message') %> Feedback<% if (typeof openFeedback !== 'undefined' && openFeedback) { %> <span class="tab-count"><%= openFeedback %></span><% } %></a><% } %>
          <a href="/account"><%- icon('users') %> Profile</a>
          <form action="/logout" method="post"><button type="submit"><%- icon('logout') %> Log out</button></form>
        <% } else { %>
          <a href="/login"><%- icon('lock') %> Staff Login</a>
        <% } %>
      </div>
    </div>
  </nav>
</header>
