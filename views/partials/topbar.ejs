<header class="topbar">
  <button class="icon-btn menu-toggle" id="menuToggle" aria-label="Toggle navigation">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>

  <a class="brand" href="/home" title="<%= siteName %>">
    <img class="brand-logo" src="/assets/favicon-og.svg" alt="<%= siteName %>" width="36" height="36" />
  </a>

  <div class="search" role="search">
    <svg class="search-ico" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="searchInput" type="text" placeholder="Search the docs..." autocomplete="off" spellcheck="false" />
    <kbd>/</kbd>
    <div id="searchResults" class="search-results" hidden></div>
  </div>

  <nav class="top-actions">
    <a class="top-link" href="/home"><%- icon('file') %> Public Documents</a>
    <% if (user) { %>
      <a class="top-link" href="/internal-documents/general-staff-handbook"><%- icon('lock') %> Internal Documents</a>
      <% if (canEdit) { %><a class="top-link" href="/admin">Dashboard</a><% } %>
      <form action="/logout" method="post" class="inline"><button class="btn btn-ghost btn-sm" type="submit"><%- icon('logout') %> Log out</button></form>
    <% } else { %>
      <a class="top-link" href="/login">Staff Login</a>
    <% } %>
    <a class="btn btn-primary" href="<%= discord %>" target="_blank" rel="noopener"><%- icon('discord') %> Join our Discord ›</a>
    <button class="icon-btn" id="themeToggle" aria-label="Toggle theme" title="Toggle theme">
      <svg class="ico-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="4.9" y1="4.9" x2="7" y2="7"/><line x1="17" y1="17" x2="19.1" y2="19.1"/><line x1="4.9" y1="19.1" x2="7" y2="17"/><line x1="17" y1="7" x2="19.1" y2="4.9"/></svg>
      <svg class="ico-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>
    </button>
  </nav>
</header>
