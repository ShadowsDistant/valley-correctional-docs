<div class="policy-back" role="dialog" aria-modal="true" aria-labelledby="policyTitle">
  <div class="policy-modal">
    <div class="policy-head">
      <img class="policy-logo" src="/assets/logo.png" alt="VCF" width="64" height="64" />
      <div>
        <div class="policy-eyebrow">Valley Correctional Facility</div>
        <h2 id="policyTitle">Staff Policy Agreement</h2>
      </div>
    </div>
    <p class="policy-intro">Before accessing staff resources you must read and accept the terms below. Your acceptance is recorded against your account, and you'll be asked again whenever the policy is updated.</p>
    <div class="policy-body">
      <ul>
        <% policyClauses.forEach(function (c) { %><li><%- policyLine(c) %></li><% }); %>
      </ul>
    </div>
    <form method="post" action="/account/agree" class="policy-actions">
      <label class="policy-check"><input type="checkbox" id="policyChk" required /> <span>I have read and agree to the Staff Policy Agreement.</span></label>
      <button class="btn btn-solid" type="submit" id="policyAgree" disabled><%- icon('check') %> Agree &amp; continue</button>
    </form>
    <form method="post" action="/account/decline" class="policy-decline"
      data-confirm="Declining the Staff Policy permanently deletes your VCF staff account. This cannot be undone — you'll lose all access." data-confirm-title="Decline &amp; delete account" data-confirm-ok="Delete my account">
      <button class="btn btn-ghost btn-sm" type="submit">Decline &amp; delete account</button>
    </form>
  </div>
</div>
<script>
  (function () {
    var c = document.getElementById('policyChk'), b = document.getElementById('policyAgree');
    if (c && b) c.addEventListener('change', function () { b.disabled = !c.checked; });
  })();
</script>
