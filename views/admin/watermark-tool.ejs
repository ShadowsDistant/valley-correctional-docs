<%- include('../partials/head') %>
<%- include('../partials/topbar') %>
<div class="layout">
  <%- include('../partials/admin-side') %>
  <main class="content admin-content">
    <div class="admin-titlerow">
      <div>
        <h1 class="admin-h1">Watermark Reveal</h1>
        <p class="admin-sub">A forensic tool for tracing leaked screenshots back to the staff member they were captured by, using the invisible per-user watermark. All processing stays in your browser.</p>
      </div>
    </div>

    <div class="wm-tool">
      <div id="wmDrop" class="wm-drop">
        <input type="file" id="wmFile" accept="image/*" hidden />
        <div class="wm-drop-inner">
          <span class="wm-drop-ico"><%- icon('files') %></span>
          <strong>Drop an image here, paste from clipboard (Ctrl+V), or <button type="button" id="wmBrowse" class="linkbtn">browse</button></strong>
          <span class="muted small">The watermark is invisible on screen by design — it only appears through this tool's amplification.</span>
        </div>
      </div>

      <div id="wmStage" class="wm-stage" hidden>
        <div class="wm-controls">
          <div class="wm-tool-actions">
            <button type="button" class="btn btn-solid btn-sm" id="wmAuto"><%- icon('search') %> Auto-reveal</button>
            <button type="button" class="btn btn-ghost btn-sm" id="wmReset">Original</button>
            <button type="button" class="btn btn-ghost btn-sm" id="wmClear">Load another</button>
          </div>
          <label>Reveal strength <span class="wm-val" id="vGain">120×</span>
            <input type="range" id="wmGain" min="10" max="300" value="120" />
          </label>
          <div class="wm-manual-head muted small">Manual adjustments (optional)</div>
          <label>Brightness <span class="wm-val" id="vBright">100%</span>
            <input type="range" id="wmBright" min="10" max="800" value="100" />
          </label>
          <label>Contrast <span class="wm-val" id="vContrast">100%</span>
            <input type="range" id="wmContrast" min="100" max="2000" value="100" />
          </label>
          <label>Saturation <span class="wm-val" id="vSat">100%</span>
            <input type="range" id="wmSat" min="0" max="600" value="100" />
          </label>
          <label>Invert <span class="wm-val" id="vInvert">0%</span>
            <input type="range" id="wmInvert" min="0" max="100" value="0" />
          </label>
        </div>
        <div class="wm-canvas-wrap">
          <canvas id="wmCanvas"></canvas>
        </div>
      </div>
    </div>
  </main>
</div>
<script>
(function () {
  var drop = document.getElementById('wmDrop'), stage = document.getElementById('wmStage');
  var fileInput = document.getElementById('wmFile'), canvas = document.getElementById('wmCanvas');
  var ctx = canvas.getContext('2d');
  // Keep the untouched source pixels in an offscreen canvas.
  var srcCanvas = document.createElement('canvas');
  var sctx = srcCanvas.getContext('2d', { willReadFrequently: true });
  var loaded = false;
  var MAX = 3200; // cap huge images for speed; watermark glyphs survive the scale

  var ctrl = {
    gain: document.getElementById('wmGain'),
    bright: document.getElementById('wmBright'), contrast: document.getElementById('wmContrast'),
    sat: document.getElementById('wmSat'), invert: document.getElementById('wmInvert')
  };
  var val = {
    gain: document.getElementById('vGain'),
    bright: document.getElementById('vBright'), contrast: document.getElementById('vContrast'),
    sat: document.getElementById('vSat'), invert: document.getElementById('vInvert')
  };
  function labels() {
    val.gain.textContent = ctrl.gain.value + '×';
    val.bright.textContent = ctrl.bright.value + '%';
    val.contrast.textContent = ctrl.contrast.value + '%';
    val.sat.textContent = ctrl.sat.value + '%';
    val.invert.textContent = ctrl.invert.value + '%';
  }

  // Manual mode: plain CSS-filter pass over the original.
  function drawManual() {
    if (!loaded) return;
    labels();
    canvas.width = srcCanvas.width; canvas.height = srcCanvas.height;
    ctx.filter = 'brightness(' + (ctrl.bright.value / 100) + ') contrast(' + (ctrl.contrast.value / 100) +
      ') saturate(' + (ctrl.sat.value / 100) + ') invert(' + (ctrl.invert.value / 100) + ')';
    ctx.drawImage(srcCanvas, 0, 0);
    ctx.filter = 'none';
  }

  // Auto-reveal: forensic high-pass, per channel. The watermark is a tiny
  // (1–3/255) local offset that may live in a single color channel (it's a
  // chroma-only blue stamp), so we blur each channel, take the residual with
  // the largest magnitude at each pixel, and amplify it around mid-gray.
  // Works no matter how dark the screenshot is (naive brightness/contrast
  // clips dark images to black).
  function boxBlur(src, w, h) {
    var R = 4, n = w * h;
    var tmp = new Float32Array(n), out = new Float32Array(n);
    var pre = new Float32Array(Math.max(w, h) + 1);
    var x, y, row, a, b;
    for (y = 0; y < h; y++) {
      row = y * w; pre[0] = 0;
      for (x = 0; x < w; x++) pre[x + 1] = pre[x] + src[row + x];
      for (x = 0; x < w; x++) {
        a = Math.max(0, x - R); b = Math.min(w - 1, x + R);
        tmp[row + x] = (pre[b + 1] - pre[a]) / (b - a + 1);
      }
    }
    for (x = 0; x < w; x++) {
      pre[0] = 0;
      for (y = 0; y < h; y++) pre[y + 1] = pre[y] + tmp[y * w + x];
      for (y = 0; y < h; y++) {
        a = Math.max(0, y - R); b = Math.min(h - 1, y + R);
        out[y * w + x] = (pre[b + 1] - pre[a]) / (b - a + 1);
      }
    }
    return out;
  }

  function autoReveal() {
    if (!loaded) return;
    labels();
    var w = srcCanvas.width, h = srcCanvas.height;
    var d = sctx.getImageData(0, 0, w, h).data;
    var n = w * h;
    var chR = new Float32Array(n), chG = new Float32Array(n), chB = new Float32Array(n);
    for (var i = 0, p = 0; i < n; i++, p += 4) { chR[i] = d[p]; chG[i] = d[p + 1]; chB[i] = d[p + 2]; }
    var bR = boxBlur(chR, w, h), bG = boxBlur(chG, w, h), bB = boxBlur(chB, w, h);

    var gain = +ctrl.gain.value;
    canvas.width = w; canvas.height = h;
    var out = ctx.createImageData(w, h), o = out.data;
    for (i = 0, p = 0; i < n; i++, p += 4) {
      var rr = chR[i] - bR[i], rg = chG[i] - bG[i], rb = chB[i] - bB[i];
      var res = rr;
      if (Math.abs(rg) > Math.abs(res)) res = rg;
      if (Math.abs(rb) > Math.abs(res)) res = rb;
      var v = 128 + res * gain;
      v = v < 0 ? 0 : v > 255 ? 255 : v;
      o[p] = o[p + 1] = o[p + 2] = v; o[p + 3] = 255;
    }
    ctx.putImageData(out, 0, 0);
  }

  ['bright', 'contrast', 'sat', 'invert'].forEach(function (k) { ctrl[k].addEventListener('input', drawManual); });
  ctrl.gain.addEventListener('input', autoReveal);
  document.getElementById('wmAuto').addEventListener('click', autoReveal);
  document.getElementById('wmReset').addEventListener('click', function () {
    ctrl.bright.value = 100; ctrl.contrast.value = 100; ctrl.sat.value = 100; ctrl.invert.value = 0; drawManual();
  });
  document.getElementById('wmClear').addEventListener('click', function () {
    stage.hidden = true; drop.classList.remove('has-img'); loaded = false; fileInput.value = '';
  });

  function load(src) {
    var img = new Image();
    img.onload = function () {
      var s = Math.min(1, MAX / Math.max(img.naturalWidth, img.naturalHeight));
      srcCanvas.width = Math.max(1, Math.round(img.naturalWidth * s));
      srcCanvas.height = Math.max(1, Math.round(img.naturalHeight * s));
      sctx.drawImage(img, 0, 0, srcCanvas.width, srcCanvas.height);
      loaded = true;
      stage.hidden = false; drop.classList.add('has-img');
      autoReveal(); // reveal immediately — that's what you came here for
    };
    img.src = src;
  }
  function handleFile(f) { if (!f || !/^image\//.test(f.type)) return; var r = new FileReader(); r.onload = function () { load(r.result); }; r.readAsDataURL(f); }

  document.getElementById('wmBrowse').addEventListener('click', function (e) { e.stopPropagation(); fileInput.click(); });
  drop.addEventListener('click', function (e) { if (e.target.tagName !== 'BUTTON') fileInput.click(); });
  fileInput.addEventListener('change', function () { handleFile(fileInput.files[0]); });
  ['dragover', 'dragenter'].forEach(function (ev) { drop.addEventListener(ev, function (e) { e.preventDefault(); drop.classList.add('drag'); }); });
  ['dragleave', 'drop'].forEach(function (ev) { drop.addEventListener(ev, function (e) { e.preventDefault(); drop.classList.remove('drag'); }); });
  drop.addEventListener('drop', function (e) { if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]); });
  window.addEventListener('paste', function (e) {
    var items = (e.clipboardData || {}).items || [];
    for (var i = 0; i < items.length; i++) { if (/^image\//.test(items[i].type)) { handleFile(items[i].getAsFile()); break; } }
  });
})();
</script>
<%- include('../partials/foot') %>
