<%- include('../partials/head') %>
<%- include('../partials/topbar') %>
<%
  function fmtDur(s) {
    if (s == null) return '<span class="muted">—</span>';
    if (s < 60) return s + 's';
    var m = Math.floor(s / 60), r = s % 60;
    if (m < 60) return m + 'm' + (r ? ' ' + r + 's' : '');
    var h = Math.floor(m / 60); return h + 'h ' + (m % 60) + 'm';
  }
%>
<div class="layout">
  <%- include('../partials/admin-side') %>
  <main class="content admin-content">
    <div class="admin-titlerow">
      <div>
        <a class="back-link" href="/admin/staff">← Back to staff</a>
        <h1 class="admin-h1"><span class="staff-avatar sm" data-rbx-avatar="<%= target.username %>"><%= (target.username||'?').slice(0,1).toUpperCase() %></span> <%= target.username %></h1>
        <p class="admin-sub"><span class="badge cap <%= target.role==='admin'?'badge-internal':'' %>"><%= target.role %></span><% (rankLabels||[]).forEach(function(rl){ %> <span class="badge badge-internal"><%= rl %></span><% }); %><% if (target.terminated) { %> <span class="badge badge-danger">Terminated</span><% } else if (target.suspended) { %> <span class="badge badge-danger">Suspended<% if (target.suspended_until) { %> until <time data-time="<%= target.suspended_until %>" data-time-format="datetime"><%= target.suspended_until.slice(0,10) %></time><% } %></span><% } %><% if (target.deleted) { %> <span class="badge badge-danger">Archived</span><% } %>
          <% if (target.timezone) { %><span class="badge" data-tip="<%= target.timezone %>"><%- icon('clock') %> <span class="ov-localtime" data-tz="<%= target.timezone %>">—</span></span><% } %></p>
      </div>
    </div>

    <!-- Roblox account (extensive) -->
    <div class="ov-roblox" id="ovRoblox" data-user="<%= target.username %>">
      <div class="ov-rbx-avatar" data-rbx-avatar="<%= target.username %>"></div>
      <div class="ov-rbx-info"><div class="roblox-label">Roblox account</div><div class="ov-rbx-name"><strong>@<%= target.username %></strong> <span class="muted small">— loading…</span></div><div class="ov-rbx-meta muted small"></div></div>
    </div>

    <% if (typeof points === 'number' && points !== null) { %>
      <div class="ov-points">Disciplinary points (6-month rolling): <span class="pill pill-<%= points>=6?'red':(points>=3?'amber':'grey') %>"><%= points %> pts</span></div>
    <% } %>

    <!-- Disciplinary records (gated by viewer division access) -->
    <% if (seeSID && (infReceived || infIssued)) { %>
      <div class="admin-cols">
        <section class="panel"><div class="panel-head"><h2>Infractions received (<%= (infReceived||[]).length %>)</h2></div>
          <% if (!(infReceived||[]).length) { %><p class="muted small">None.</p><% } else { %><div class="table-scroll"><table class="table"><thead><tr><th>Type</th><th class="num">Pts</th><th>Outcome</th><th>By</th><th>When</th></tr></thead><tbody>
            <% infReceived.forEach(function(f){ %><tr class="<%= f.voided?'row-void':'' %>"><td class="small"><%= f.type %></td><td class="num mono"><%= f.points %></td><td class="small"><% if(f.outcome){ %><span class="pill pill-<%= /Termination/.test(f.outcome)?'red':(/Suspension/.test(f.outcome)?'amber':'grey') %>"><%= f.outcome %></span><% } %></td><td class="small"><%= f.issued_by %></td><td class="small nowrap"><time data-time="<%= f.created_at %>"><%= f.created_at.slice(0,10) %></time></td></tr><% }); %>
          </tbody></table></div><% } %></section>
        <section class="panel"><div class="panel-head"><h2>Infractions issued (<%= (infIssued||[]).length %>)</h2></div>
          <% if (!(infIssued||[]).length) { %><p class="muted small">None.</p><% } else { %><div class="table-scroll"><table class="table"><thead><tr><th>Staff</th><th class="num">Pts</th><th>Type</th><th>When</th></tr></thead><tbody>
            <% infIssued.forEach(function(f){ %><tr class="<%= f.voided?'row-void':'' %>"><td class="small"><strong><%= f.staff_user %></strong></td><td class="num mono"><%= f.points %></td><td class="small"><%= f.type %></td><td class="small nowrap"><time data-time="<%= f.created_at %>"><%= f.created_at.slice(0,10) %></time></td></tr><% }); %>
          </tbody></table></div><% } %></section>
      </div>
    <% } %>
    <% if (seeMod && (punReceived || punIssued)) { %>
      <div class="admin-cols">
        <section class="panel"><div class="panel-head"><h2>Punishments received (<%= (punReceived||[]).length %>)</h2></div>
          <% if (!(punReceived||[]).length) { %><p class="muted small">None.</p><% } else { %><div class="table-scroll"><table class="table"><thead><tr><th>Type</th><th>Reason</th><th>By</th><th>When</th></tr></thead><tbody>
            <% punReceived.forEach(function(p){ %><tr class="<%= p.voided?'row-void':'' %>"><td><span class="pill pill-<%= /ban/i.test(p.type)?'red':'amber' %>"><%= p.type %></span></td><td class="small"><%= p.reason %></td><td class="small"><%= p.moderator %></td><td class="small nowrap"><time data-time="<%= p.created_at %>"><%= p.created_at.slice(0,10) %></time></td></tr><% }); %>
          </tbody></table></div><% } %></section>
        <section class="panel"><div class="panel-head"><h2>Punishments issued (<%= (punIssued||[]).length %>)</h2></div>
          <% if (!(punIssued||[]).length) { %><p class="muted small">None.</p><% } else { %><div class="table-scroll"><table class="table"><thead><tr><th>Roblox user</th><th>Type</th><th>When</th></tr></thead><tbody>
            <% punIssued.forEach(function(p){ %><tr class="<%= p.voided?'row-void':'' %>"><td class="mono small"><%= p.roblox_user %></td><td><span class="pill pill-<%= /ban/i.test(p.type)?'red':'amber' %>"><%= p.type %></span></td><td class="small nowrap"><time data-time="<%= p.created_at %>"><%= p.created_at.slice(0,10) %></time></td></tr><% }); %>
          </tbody></table></div><% } %></section>
      </div>
    <% } %>

    <h2 class="ov-section-h">Document activity</h2>
    <div class="stat-grid">
      <div class="stat-card"><span class="stat-num"><%= stats.totalViews %></span><span class="stat-label">Total page views</span></div>
      <div class="stat-card"><span class="stat-num"><%= stats.uniquePages %></span><span class="stat-label">Unique pages</span></div>
      <div class="stat-card"><span class="stat-num"><%- fmtDur(stats.totalTime) %></span><span class="stat-label">Time reading (est.)</span></div>
      <div class="stat-card"><span class="stat-num"><% if (target.last_login) { %><time data-time="<%= target.last_login %>" class="stat-time"><%= target.last_login.slice(0,16).replace('T',' ') %></time><% } else { %>never<% } %></span><span class="stat-label">Last login</span></div>
    </div>

    <section class="panel panel-flush">
      <div class="table-scroll">
        <table class="table">
          <thead><tr><th>Page</th><th>When</th><th class="num">Time on page</th></tr></thead>
          <tbody>
            <% if (!items.length) { %>
              <tr><td colspan="3" class="muted" style="padding:18px">No document activity recorded for this account yet.</td></tr>
            <% } %>
            <% items.forEach(function (it, idx) { %>
              <tr class="act-row" <%= idx >= 15 ? 'hidden' : '' %>>
                <td>
                  <% if (it.slug && !/^(admin|dashboard):/.test(it.slug)) { %><a href="/<%= it.slug %>" target="_blank"><% if (it.internal) { %><span class="ic ic-lock"></span> <% } %><%= it.title %></a><% } else if (it.slug) { %><span class="mono small"><%= it.slug %></span><% } else { %><span class="mono small"><%= it.path %></span><% } %>
                </td>
                <td class="muted small"><time data-time="<%= it.ts %>"><%= it.ts %></time></td>
                <td class="num mono small"><%- fmtDur(it.duration) %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% if (items.length > 15) { %>
        <div class="act-more-row"><button class="btn btn-ghost btn-sm" type="button" id="actMore">View more (<span id="actHiddenCount"><%= items.length - 15 %></span> hidden)</button></div>
      <% } %>
    </section>
    <p class="muted small">Time on page is estimated from the gap between consecutive views (capped at 15 minutes); the most recent view has no measured duration.</p>

    <% if (isAdminViewer) { %>
      <section class="panel">
        <div class="panel-head"><h2><%- icon('key') %> Passkeys</h2><span class="badge <%= (targetPasskeys && targetPasskeys.length) ? 'badge-internal' : '' %>"><%= (targetPasskeys && targetPasskeys.length) ? (targetPasskeys.length + ' · 2FA on') : 'none' %></span></div>
        <% if (!targetPasskeys || !targetPasskeys.length) { %>
          <p class="muted small" style="margin:0"><strong><%= target.username %></strong> has no passkeys — they sign in with a password only.</p>
        <% } else { %>
          <p class="muted small ai-log-note">Remove a passkey if this staff member lost the device. Removing their last one drops the account back to password-only.</p>
          <ul class="pk-list">
            <% targetPasskeys.forEach(function (p) { %>
              <li class="pk-item">
                <span class="pk-ico"><%- icon('key') %></span>
                <div class="pk-meta"><strong><%= p.name %></strong><span class="muted small">Added <time data-time="<%= p.created_at %>"><%= p.created_at.slice(0,10) %></time><% if (p.last_used) { %> · last used <time data-time="<%= p.last_used %>"><%= p.last_used.slice(0,10) %></time><% } %></span></div>
                <form method="post" action="/admin/staff/passkey/remove" class="inline" data-confirm="Remove <%= target.username %>'s passkey &quot;<%= p.name %>&quot;? They'll need to re-enrol on their device." data-confirm-title="Remove passkey" data-confirm-ok="Remove">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="passkey_id" value="<%= p.id %>" />
                  <input type="hidden" name="user_id" value="<%= target.id %>" />
                  <button class="btn btn-ghost btn-sm" type="submit"><%- icon('trash') %> Remove</button>
                </form>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </section>

      <section class="panel ai-log-panel">
        <div class="panel-head">
          <h2><%- icon('message') %> Assistant conversations</h2>
          <span class="badge badge-internal">Admins only</span>
        </div>
        <% if (!aiChats || !aiChats.length) { %>
          <p class="muted small" style="margin:0">This staff member hasn't used the VCF Assistant yet.</p>
        <% } else { %>
          <p class="muted small ai-log-note">Every question <strong><%= target.username %></strong> asked the assistant, with the model's reasoning. Staff are told their conversations are saved and reviewable.</p>
          <ul class="ai-log-list">
            <% aiChats.forEach(function (c) { %>
              <li class="ai-log-item" data-ailog="<%= c.id %>">
                <button type="button" class="ai-log-open">
                  <span class="ai-log-caret"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg></span>
                  <span class="ai-log-title"><%= c.title %></span>
                  <span class="ai-log-meta"><%= c.n %> msg · <time data-time="<%= c.updated_at %>"><%= c.updated_at %></time></span>
                </button>
                <div class="ai-log-body" hidden></div>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </section>
    <% } %>
<script>
(function () {
  // "View more" reveals the doc-activity table 25 rows at a time.
  var more = document.getElementById('actMore');
  if (more) more.addEventListener('click', function () {
    var hidden = document.querySelectorAll('.act-row[hidden]');
    for (var i = 0; i < Math.min(25, hidden.length); i++) hidden[i].hidden = false;
    var left = document.querySelectorAll('.act-row[hidden]').length;
    if (!left) more.parentNode.remove();
    else document.getElementById('actHiddenCount').textContent = left;
  });
  // The staff member's current local time, ticking each minute.
  var lt = document.querySelector('.ov-localtime');
  if (lt) {
    var tz = lt.getAttribute('data-tz');
    function tick() {
      try { lt.textContent = new Date().toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit', timeZone: tz }) + ' — ' + tz.split('/').pop().replace(/_/g, ' '); }
      catch (e) { lt.textContent = tz; }
    }
    tick(); var iv = setInterval(tick, 30000);
    if (window.pjaxRegister) window.pjaxRegister(function () { clearInterval(iv); });
  }
})();
(function () {
  // Assistant conversation viewer (admin only) — lazy-loads each thread.
  var list = document.querySelector('.ai-log-list'); if (!list) return;
  function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]; }); }
  function strip(s) { return esc(s).replace(/\[\[([^\]|]+)\|[^\]]+\]\]/g, '<span class="ai-log-cite">$1</span>'); }
  list.addEventListener('click', function (e) {
    var btn = e.target.closest('.ai-log-open'); if (!btn) return;
    var item = btn.closest('.ai-log-item');
    var body = item.querySelector('.ai-log-body');
    if (!body.hidden) { body.hidden = true; item.classList.remove('open'); return; }
    item.classList.add('open'); body.hidden = false;
    if (item.dataset.loaded) return;
    body.innerHTML = '<p class="muted small">Loading…</p>';
    fetch('/admin/ai-chat?id=' + encodeURIComponent(item.getAttribute('data-ailog')))
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (!d.ok) { body.innerHTML = '<p class="muted small">Could not load.</p>'; return; }
        item.dataset.loaded = '1';
        body.innerHTML = d.messages.map(function (m) {
          if (m.role === 'user') return '<div class="ai-log-turn is-q"><span class="ai-log-who">Asked</span><div>' + esc(m.content) + '</div></div>';
          var th = m.thinking
            ? '<details class="ai-log-think"><summary>Model reasoning</summary><pre>' + esc(m.thinking) + '</pre></details>' : '';
          return '<div class="ai-log-turn is-a"><span class="ai-log-who">Answered</span><div>' + strip(m.content).replace(/\n/g, '<br>') + '</div>' + th + '</div>';
        }).join('') || '<p class="muted small">Empty conversation.</p>';
      })
      .catch(function () { body.innerHTML = '<p class="muted small">Could not load.</p>'; });
  });
})();
(function () {
  var box = document.getElementById('ovRoblox'); if (!box) return;
  var name = box.getAttribute('data-user');
  fetch('/api/roblox/' + encodeURIComponent(name)).then(function (r) { return r.json(); }).then(function (d) {
    var nm = box.querySelector('.ov-rbx-name'), meta = box.querySelector('.ov-rbx-meta');
    if (!d.ok) { nm.innerHTML = '<strong>@' + name + '</strong> <span class="muted small">— no matching Roblox account</span>'; return; }
    nm.innerHTML = '<strong>' + d.displayName + '</strong> <span class="muted">@' + d.name + '</span>';
    meta.innerHTML = 'Roblox ID ' + d.id + ' · <a href="https://www.roblox.com/users/' + d.id + '/profile" target="_blank" rel="noopener">open profile ↗</a>'
      + (typeof d.priorPunishments === 'number' ? ' · ' + d.priorPunishments + ' prior punishment' + (d.priorPunishments === 1 ? '' : 's') : '');
  }).catch(function () {});
})();
</script>
  </main>
</div>
<%- include('../partials/foot') %>
