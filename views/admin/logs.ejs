<%- include('../partials/head') %>
<%- include('../partials/topbar') %>
<div class="layout">
  <%- include('../partials/admin-side') %>
  <main class="content admin-content">
    <h1 class="admin-h1">Activity log</h1>
    <p class="admin-sub">Who did what, and when. Logins, content edits, page and account changes, and policy updates are recorded here.</p>

    <%
      var ACTION = {
        'user.login': ['Signed in', 'act-login'], 'user.logout': ['Signed out', 'act-neutral'],
        'user.login_fail': ['Failed login', 'act-delete'], 'user.login_blocked': ['Blocked login', 'act-delete'],
        'user.login_locked': ['Locked out (throttle)', 'act-delete'], 'user.rename': ['Renamed account', 'act-edit'],
        'user.login_2fa_fail': ['Failed passkey check', 'act-delete'],
        'system.update_requested': ['Update requested', 'act-neutral'], 'pages.pending_dismissed': ['Reviewed doc update', 'act-neutral'],
        'passkey.add': ['Added passkey', 'act-create'], 'passkey.remove': ['Removed passkey', 'act-delete'], 'passkey.admin_remove': ['Admin removed passkey', 'act-delete'],
        'page.create': ['Created page', 'act-create'], 'page.update': ['Edited page', 'act-edit'],
        'page.delete': ['Deleted page', 'act-delete'], 'page.restore': ['Restored page', 'act-edit'],
        'user.create': ['Created account', 'act-create'], 'user.role': ['Changed role', 'act-edit'],
        'user.suspend': ['Suspended account', 'act-delete'], 'user.reinstate': ['Reinstated account', 'act-create'],
        'user.delete': ['Deleted account', 'act-delete'], 'user.password': ['Changed own password', 'act-edit'],
        'user.password_reset': ['Reset password', 'act-edit'], 'user.agree': ['Accepted policy', 'act-neutral'],
        'policy.update': ['Updated staff policy', 'act-edit'], 'policy.decline': ['Declined policy (deleted)', 'act-delete'],
        'shift.create': ['Added event', 'act-create'], 'shift.delete': ['Removed event', 'act-delete'],
        'security.screenshot': ['Screenshot attempt', 'act-delete'],
        'punish.create': ['Punishment logged', 'act-edit'], 'punish.void': ['Punishment voided', 'act-neutral'],
        'punish.delete': ['Punishment DELETED', 'act-delete'], 'infraction.delete': ['Infraction DELETED', 'act-delete'],
        'punish.approve': ['Punishment approved', 'act-create'], 'punish.reject': ['Punishment rejected', 'act-delete'],
        'infraction.create': ['Infraction issued', 'act-delete'], 'infraction.void': ['Infraction voided', 'act-neutral'],
        'infraction.approve': ['Infraction approved', 'act-create'], 'infraction.reject': ['Infraction rejected', 'act-delete'],
        'file.upload': ['File uploaded', 'act-neutral'], 'user.rank': ['Changed rank', 'act-edit'],
        'user.terminated': ['Auto-terminated', 'act-delete'],
        'user.archive': ['Archived account', 'act-delete'], 'user.suspension_expired': ['Suspension expired', 'act-neutral'],
        'feedback.create': ['Feedback submitted', 'act-create'], 'feedback.status': ['Feedback reviewed', 'act-edit'],
        'feedback.blocked': ['Feedback blocked (language)', 'act-delete'], 'feedback.msg_delete': ['Feedback message deleted', 'act-delete'],
      };
      function actionLabel(a) { return (ACTION[a] || [a, 'act-neutral']); }
    %>

    <form method="get" action="/admin/logs" class="log-filters">
      <label class="field field-sm">Action
        <select name="action">
          <option value="">All actions</option>
          <% actions.forEach(function (a) { %><option value="<%= a %>" <%= filter.action === a ? 'selected' : '' %>><%= actionLabel(a)[0] %></option><% }); %>
        </select>
      </label>
      <label class="field field-sm">User<input type="text" name="actor" value="<%= filter.actor %>" placeholder="username" autocomplete="off" data-suggest="actor" /></label>
      <label class="field field-sm">From<input type="date" name="from" value="<%= filter.from %>" /></label>
      <label class="field field-sm">To<input type="date" name="to" value="<%= filter.to %>" /></label>
      <div class="log-filter-actions">
        <button class="btn btn-solid btn-sm" type="submit"><%- icon('search') %> Filter</button>
        <% if (filter.action || filter.actor || filter.from || filter.to) { %><a class="btn btn-ghost btn-sm" href="/admin/logs">Clear</a><% } %>
      </div>
    </form>

    <section class="panel panel-flush">
      <div class="table-scroll">
      <table class="table logs-table">
        <thead><tr><th>When</th><th>Who</th><th>Action</th><th>Target</th><th>Details</th></tr></thead>
        <tbody>
          <% if (!events.length) { %><tr><td colspan="5" class="muted" style="padding:18px">No matching activity.</td></tr><% } %>
          <% events.forEach(function (e, i) { var a = actionLabel(e.action); %>
            <tr class="log-row"<%= i >= 15 ? ' hidden' : '' %>>
              <td class="muted small nowrap"><time data-time="<%= e.ts %>"><%= (e.ts || '').replace('T',' ') %></time></td>
              <td><strong><%= e.actor %></strong></td>
              <td><span class="act-badge <%= a[1] %>"><%= a[0] %></span></td>
              <td class="mono small"><% if (/^\//.test(e.target)) { %><a href="<%= e.target %>" target="_blank"><%= e.target %></a><% } else { %><%= e.target %><% } %></td>
              <td class="muted small"><%= e.details %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      </div>
      <% if (events.length > 15) { %>
        <div class="log-more-row"><button class="btn btn-ghost btn-sm" type="button" id="logMore">View more (<span id="logHidden"><%= events.length - 15 %></span> older)</button></div>
      <% } %>
    </section>
<script>
(function () {
  var more = document.getElementById('logMore'); if (!more) return;
  more.addEventListener('click', function () {
    var hidden = document.querySelectorAll('.log-row[hidden]');
    for (var i = 0; i < Math.min(25, hidden.length); i++) hidden[i].hidden = false;
    var left = document.querySelectorAll('.log-row[hidden]').length;
    if (!left) more.parentNode.remove();
    else document.getElementById('logHidden').textContent = left;
  });
})();
</script>
  </main>
</div>
<%- include('../partials/foot') %>
