<%- include('../partials/head') %>
<%- include('../partials/topbar') %>
<div class="layout">
  <%- include('../partials/admin-side') %>
  <main class="content admin-content">
    <div class="admin-titlerow">
      <div>
        <h1 class="admin-h1">System <span class="sys-live" id="sysLive"><span class="sys-live-dot"></span>live</span></h1>
        <p class="admin-sub">Live health of the server this site runs on, the build that's deployed, and one-click updates. Refreshes every couple of seconds.</p>
      </div>
      <div class="sys-build-chip" data-tip="The commit currently running" data-tip-pos="left">
        <span class="sys-build-dot"></span>
        <span class="mono" id="sysBuild"><%= stats.build.commit ? stats.build.commit : 'v' + stats.build.version %></span>
      </div>
    </div>

    <div class="stat-grid stat-grid-ico sys-grid">
      <div class="stat-card">
        <span class="stat-ico"><%- icon('chart') %></span>
        <span class="stat-num" id="sysCpu">—</span>
        <span class="stat-label">CPU load · 1 min</span>
        <div class="sys-meter"><span id="sysCpuBar" style="width:0%"></span></div>
        <span class="muted small" id="sysCpuSub">—</span>
      </div>
      <div class="stat-card">
        <span class="stat-ico"><%- icon('sitemap') %></span>
        <span class="stat-num" id="sysMem">—</span>
        <span class="stat-label">Memory used</span>
        <div class="sys-meter"><span id="sysMemBar" style="width:0%"></span></div>
        <span class="muted small" id="sysMemSub">—</span>
      </div>
      <div class="stat-card">
        <span class="stat-ico"><%- icon('cabinet') %></span>
        <span class="stat-num" id="sysDisk">—</span>
        <span class="stat-label">Disk used</span>
        <div class="sys-meter"><span id="sysDiskBar" style="width:0%"></span></div>
        <span class="muted small" id="sysDiskSub">—</span>
      </div>
      <div class="stat-card">
        <span class="stat-ico"><%- icon('timer') %></span>
        <span class="stat-num" id="sysUp">—</span>
        <span class="stat-label">Server uptime</span>
        <span class="muted small" id="sysUpSub">—</span>
      </div>
    </div>

    <section class="panel sys-hist-panel">
      <div class="panel-head">
        <h2><%- icon('chart') %> Usage history</h2>
        <span class="muted small" id="sysHistRange">last 30 minutes · sampled every 10s</span>
      </div>
      <div class="sys-hist-grid">
        <div class="sys-hist" data-metric="cpu">
          <div class="sys-hist-head"><span class="sys-hist-label"><i class="sys-hist-key key-cpu"></i>CPU load</span><span class="sys-hist-now mono" id="sysHistCpuNow">—</span></div>
          <div class="sys-hist-plot"><canvas id="sysHistCpu" height="120"></canvas><div class="chart-tip sys-hist-tip" hidden></div></div>
        </div>
        <div class="sys-hist" data-metric="mem">
          <div class="sys-hist-head"><span class="sys-hist-label"><i class="sys-hist-key key-mem"></i>Memory used</span><span class="sys-hist-now mono" id="sysHistMemNow">—</span></div>
          <div class="sys-hist-plot"><canvas id="sysHistMem" height="120"></canvas><div class="chart-tip sys-hist-tip" hidden></div></div>
        </div>
      </div>
      <p class="muted small sys-hist-note">History is sampled by the server, so it keeps building whether or not this page is open. It resets when the app restarts.</p>
    </section>

    <div class="admin-cols sys-cols">
      <section class="panel">
        <div class="panel-head"><h2><%- icon('building') %> Machine</h2></div>
        <dl class="sys-dl" id="sysHost">
          <dt>Host</dt><dd class="mono"><%= stats.host.hostname %></dd>
          <dt>OS</dt><dd class="mono"><%= stats.host.platform %> <%= stats.host.release %> · <%= stats.host.arch %></dd>
          <dt>CPU</dt><dd class="mono"><%= stats.cpu.model %></dd>
          <dt>Cores</dt><dd class="mono"><%= stats.cpu.cores %></dd>
        </dl>
      </section>

      <section class="panel">
        <div class="panel-head"><h2><%- icon('gear') %> Application</h2></div>
        <dl class="sys-dl">
          <dt>Version</dt><dd class="mono">v<%= stats.build.version %></dd>
          <dt>Commit</dt><dd class="mono"><%= stats.build.commit || '—' %><%= stats.build.branch ? ' (' + stats.build.branch + ')' : '' %></dd>
          <% if (stats.build.subject) { %><dt>Change</dt><dd><%= stats.build.subject %></dd><% } %>
          <dt>Built</dt><dd><% if (stats.build.built) { %><time data-time="<%= String(stats.build.built).replace('T',' ').replace(/\..*/,'') %>" data-time-format="datetime"><%= stats.build.built %></time><% } else { %>—<% } %></dd>
          <dt>Node</dt><dd class="mono"><%= stats.app.node %></dd>
          <dt>Environment</dt><dd class="mono"><%= stats.app.env %></dd>
          <dt>App uptime</dt><dd class="mono" id="sysProcUp">—</dd>
          <dt>App memory</dt><dd class="mono" id="sysRss">—</dd>
          <dt>Database</dt><dd class="mono" id="sysDb">—</dd>
        </dl>
      </section>
    </div>

    <section class="panel sys-storage-panel">
      <div class="panel-head"><h2><%- icon('cabinet') %> Storage &amp; content</h2></div>
      <div class="sys-storage-grid">
        <div class="sys-store">
          <div class="sys-store-top"><span class="sys-store-label">Database</span><span class="mono" id="sysStDbTot">—</span></div>
          <dl class="sys-dl sys-store-dl">
            <dt>Main</dt><dd class="mono" id="sysStDbMain">—</dd>
            <dt>Write-ahead log</dt><dd class="mono" id="sysStDbWal">—</dd>
          </dl>
        </div>
        <div class="sys-store">
          <div class="sys-store-top"><span class="sys-store-label">Evidence uploads</span><span class="mono" id="sysStEv">—</span></div>
          <div class="sys-meter sys-store-meter"><span id="sysStEvBar" style="width:0%"></span></div>
          <span class="muted small" id="sysStEvSub">—</span>
        </div>
      </div>
      <div class="sys-count-row">
        <div class="sys-count"><span class="sys-count-n" id="sysCntDocs">—</span><span class="sys-count-l">Documents</span></div>
        <div class="sys-count"><span class="sys-count-n" id="sysCntStaff">—</span><span class="sys-count-l">Staff accounts</span></div>
        <div class="sys-count"><span class="sys-count-n" id="sysCntSess">—</span><span class="sys-count-l">Active sessions</span></div>
      </div>
    </section>

    <% if (pending && pending.length) { %>
      <section class="panel sys-pending">
        <div class="panel-head">
          <h2><%- icon('shield') %> Withheld document updates</h2>
          <span class="badge badge-internal"><%= pending.length %></span>
        </div>
        <p class="muted small sys-update-copy">
          A deploy shipped new wording for these documents, but your copies have <strong>local edits</strong>, so they were
          <strong>not overwritten</strong> — updates never destroy staff work. Review each one and merge anything you want by hand.
        </p>
        <ul class="sys-pending-list">
          <% pending.forEach(function (p) { %>
            <li data-slug="<%= p.slug %>">
              <div class="sys-pending-main">
                <a class="sys-pending-title" href="/admin/edit?slug=<%= encodeURIComponent(p.slug) %>"><%- icon('edit') %> <%= p.title %></a>
                <span class="muted small">edited by <strong><%= p.editedBy %></strong><% if (p.why) { %> · shipped change: <%= p.why %><% } %></span>
              </div>
              <button type="button" class="btn btn-ghost btn-sm" data-dismiss="<%= p.slug %>">Reviewed</button>
            </li>
          <% }); %>
        </ul>
      </section>
    <% } %>

    <section class="panel sys-update">
      <div class="panel-head">
        <h2><%- icon('download') %> Updates</h2>
        <span class="sys-updater-pill" id="sysUpdaterPill">checking…</span>
      </div>
      <p class="muted small sys-update-copy">
        Pulls the latest <strong>main</strong> from GitHub and rebuilds the containers on the host.
        The site restarts for a few seconds while the new build comes up.
      </p>
      <div class="sys-update-row">
        <form method="post" action="/admin/system/update" id="sysUpdateForm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn btn-solid" type="submit" id="sysUpdateBtn"><%- icon('refresh') %> Run update</button>
        </form>
        <div class="sys-update-state" id="sysUpdateState"></div>
      </div>
      <div class="sys-updater-missing" id="sysUpdaterMissing" hidden>
        <%- icon('warning') %>
        <div>
          <strong>The host updater isn't running.</strong>
          <p class="muted small">The app is containerised and has no Docker socket (by design — it would be root on the host), so a helper on the host performs updates. Install it once:</p>
          <pre class="mono"><code>chmod +x /opt/vcf-docs/deploy/update-watcher.sh
( crontab -l 2>/dev/null; echo '* * * * * /opt/vcf-docs/deploy/update-watcher.sh >> /var/log/vcf-update.log 2>&1' ) | crontab -</code></pre>
        </div>
      </div>
    </section>

<script>
(function () {
  var $ = function (id) { return document.getElementById(id); };
  function bytes(n) {
    if (!n && n !== 0) return '—';
    var u = ['B', 'KB', 'MB', 'GB', 'TB'], i = 0;
    while (n >= 1024 && i < u.length - 1) { n /= 1024; i++; }
    return (n < 10 && i > 0 ? n.toFixed(1) : Math.round(n)) + ' ' + u[i];
  }
  function dur(s) {
    s = Math.max(0, Math.round(s));
    var d = Math.floor(s / 86400), h = Math.floor(s % 86400 / 3600), m = Math.floor(s % 3600 / 60);
    if (d) return d + 'd ' + h + 'h';
    if (h) return h + 'h ' + m + 'm';
    return m + 'm';
  }
  function meter(el, pct) {
    el.style.width = Math.max(0, Math.min(100, pct)) + '%';
    el.className = pct >= 90 ? 'is-crit' : pct >= 70 ? 'is-warn' : '';
  }
  // ---- usage history charts -------------------------------------------------
  // The samples come from the server (see sysHistory in server.js) so the graph
  // is already populated on first paint instead of drawing itself in real time.
  var HIST = { cpu: { canvas: 'sysHistCpu', colour: '#ffa200', now: 'sysHistCpuNow' },
               mem: { canvas: 'sysHistMem', colour: '#60a5fa', now: 'sysHistMemNow' } };
  var histData = [], histHover = { metric: null, i: -1 };

  function fitCanvas(c) {
    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    var w = c.clientWidth || c.parentNode.clientWidth || 300, h = c.clientHeight || 120;
    if (c.width !== Math.round(w * dpr) || c.height !== Math.round(h * dpr)) {
      c.width = Math.round(w * dpr); c.height = Math.round(h * dpr);
    }
    var x = c.getContext('2d');
    x.setTransform(dpr, 0, 0, dpr, 0, 0);
    return { ctx: x, w: w, h: h };
  }
  function drawHist(metric) {
    var cfg = HIST[metric], c = $(cfg.canvas); if (!c || !c.getContext) return;
    var f = fitCanvas(c), ctx = f.ctx, w = f.w, h = f.h;
    ctx.clearRect(0, 0, w, h);
    var padT = 6, padB = 14, ih = h - padT - padB;
    // grid + axis at 0/50/100%
    ctx.font = '9px ui-monospace, SFMono-Regular, Menlo, monospace';
    for (var g = 0; g <= 2; g++) {
      var gy = padT + ih * (g / 2);
      ctx.beginPath(); ctx.moveTo(22, gy); ctx.lineTo(w, gy);
      ctx.strokeStyle = 'rgba(255,240,214,0.08)'; ctx.lineWidth = 1; ctx.setLineDash([3, 4]); ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = 'rgba(255,240,214,0.32)'; ctx.textAlign = 'right';
      ctx.fillText((100 - g * 50) + '%', 18, gy + 3);
    }
    ctx.textAlign = 'start';
    var n = histData.length;
    if (n < 2) {
      ctx.fillStyle = 'rgba(255,240,214,0.3)';
      ctx.fillText('collecting…', 30, padT + ih / 2);
      return;
    }
    var x0 = 22, span = w - x0 - 2;
    var xOf = function (i) { return x0 + (i / (n - 1)) * span; };
    var yOf = function (v) { return padT + ih - (Math.max(0, Math.min(100, v)) / 100) * ih; };
    // area + line
    ctx.beginPath();
    for (var i = 0; i < n; i++) { var x = xOf(i), y = yOf(histData[i][metric]); i ? ctx.lineTo(x, y) : ctx.moveTo(x, y); }
    ctx.lineTo(xOf(n - 1), padT + ih); ctx.lineTo(x0, padT + ih); ctx.closePath();
    var grad = ctx.createLinearGradient(0, padT, 0, padT + ih);
    grad.addColorStop(0, cfg.colour + '55'); grad.addColorStop(1, cfg.colour + '00');
    ctx.fillStyle = grad; ctx.fill();
    ctx.beginPath();
    for (var j = 0; j < n; j++) { var xx = xOf(j), yy = yOf(histData[j][metric]); j ? ctx.lineTo(xx, yy) : ctx.moveTo(xx, yy); }
    ctx.strokeStyle = cfg.colour; ctx.lineWidth = 1.6; ctx.lineJoin = 'round'; ctx.stroke();
    // hovered sample marker
    if (histHover.metric === metric && histHover.i >= 0 && histHover.i < n) {
      var hx = xOf(histHover.i), hy = yOf(histData[histHover.i][metric]);
      ctx.beginPath(); ctx.moveTo(hx, padT); ctx.lineTo(hx, padT + ih);
      ctx.strokeStyle = 'rgba(255,240,214,0.35)'; ctx.lineWidth = 1; ctx.setLineDash([3, 3]); ctx.stroke(); ctx.setLineDash([]);
      ctx.beginPath(); ctx.arc(hx, hy, 3.5, 0, 6.2832);
      ctx.fillStyle = cfg.colour; ctx.fill();
      ctx.strokeStyle = 'rgba(0,0,0,0.5)'; ctx.lineWidth = 1.5; ctx.stroke();
    }
    // time axis: oldest -> newest
    ctx.fillStyle = 'rgba(255,240,214,0.32)';
    var mins = Math.round((histData[n - 1].t - histData[0].t) / 60000);
    ctx.fillText('-' + mins + 'm', x0 + 2, h - 3);
    ctx.textAlign = 'end'; ctx.fillText('now', w - 2, h - 3); ctx.textAlign = 'start';
  }
  function drawAllHist() { drawHist('cpu'); drawHist('mem'); }

  // hover: map pointer x back to a sample index and show its value + time
  Object.keys(HIST).forEach(function (metric) {
    var c = $(HIST[metric].canvas); if (!c) return;
    var plot = c.parentNode, tip = plot.querySelector('.sys-hist-tip');
    c.addEventListener('mousemove', function (e) {
      var n = histData.length; if (n < 2) return;
      var r = c.getBoundingClientRect();
      var x0 = 22, span = r.width - x0 - 2;
      var i = Math.round(((e.clientX - r.left) - x0) / span * (n - 1));
      i = Math.max(0, Math.min(n - 1, i));
      histHover = { metric: metric, i: i };
      var s = histData[i];
      var ago = Math.round((Date.now() - s.t) / 1000);
      tip.hidden = false;
      tip.innerHTML = '<strong>' + (ago < 60 ? ago + 's ago' : Math.round(ago / 60) + 'm ago') + '</strong>'
        + '<span>' + (metric === 'cpu' ? 'CPU ' : 'Memory ') + s[metric].toFixed(1) + '%</span>'
        + (metric === 'mem' ? '<span>' + bytes(s.rss) + ' app RSS</span>' : '');
      var px = x0 + (i / (n - 1)) * span, tw = tip.offsetWidth;
      tip.style.left = Math.max(2, Math.min(r.width - tw - 2, px - tw / 2)) + 'px';
      drawAllHist();
    });
    c.addEventListener('mouseleave', function () {
      histHover = { metric: null, i: -1 }; tip.hidden = true; drawAllHist();
    });
  });
  window.addEventListener('resize', drawAllHist);
  function paint(s) {
    var loadPct = s.cpu.cores ? (s.cpu.load[0] / s.cpu.cores) * 100 : 0;
    $('sysCpu').textContent = s.cpu.load[0].toFixed(2);
    $('sysCpuSub').textContent = Math.round(loadPct) + '% of ' + s.cpu.cores + ' core' + (s.cpu.cores === 1 ? '' : 's') + ' · 5m ' + s.cpu.load[1].toFixed(2);
    meter($('sysCpuBar'), loadPct);

    var memPct = s.memory.total ? (s.memory.used / s.memory.total) * 100 : 0;
    $('sysMem').textContent = Math.round(memPct) + '%';
    $('sysMemSub').textContent = bytes(s.memory.used) + ' of ' + bytes(s.memory.total);
    meter($('sysMemBar'), memPct);

    if (s.disk && s.disk.total) {
      var used = s.disk.total - s.disk.free, dPct = (used / s.disk.total) * 100;
      $('sysDisk').textContent = Math.round(dPct) + '%';
      $('sysDiskSub').textContent = bytes(used) + ' of ' + bytes(s.disk.total) + ' · ' + bytes(s.disk.free) + ' free';
      meter($('sysDiskBar'), dPct);
    } else { $('sysDisk').textContent = 'n/a'; $('sysDiskSub').textContent = 'not reported'; }

    $('sysUp').textContent = dur(s.host.uptime);
    $('sysUpSub').textContent = 'app running ' + dur(s.app.uptime);
    $('sysProcUp').textContent = dur(s.app.uptime);
    $('sysRss').textContent = bytes(s.app.rss) + ' RSS · ' + bytes(s.app.heapUsed) + ' heap';
    $('sysDb').textContent = bytes(s.db.bytes);

    if (s.history && s.history.length) {
      histData = s.history;
      var last = histData[histData.length - 1];
      $('sysHistCpuNow').textContent = last.cpu.toFixed(1) + '%';
      $('sysHistMemNow').textContent = last.mem.toFixed(1) + '%';
      var mins = Math.round((last.t - histData[0].t) / 60000);
      $('sysHistRange').textContent = (mins ? 'last ' + mins + ' min' : 'starting up') + ' · sampled every 10s';
      drawAllHist();
    }

    if (s.storage) {
      $('sysStDbTot').textContent = bytes(s.storage.dbTotal);
      $('sysStDbMain').textContent = bytes(s.storage.dbMain);
      $('sysStDbWal').textContent = bytes(s.storage.dbWal);
      $('sysStEv').textContent = bytes(s.storage.evidence);
      var evPct = s.storage.evidenceCap ? (s.storage.evidence / s.storage.evidenceCap) * 100 : 0;
      meter($('sysStEvBar'), evPct);
      $('sysStEvSub').textContent = Math.round(evPct) + '% of ' + bytes(s.storage.evidenceCap) + ' cap · ' + bytes(Math.max(0, s.storage.evidenceCap - s.storage.evidence)) + ' free';
    }
    if (s.counts) {
      var fmt = function (n) { return n == null ? 'n/a' : String(n); };
      $('sysCntDocs').textContent = fmt(s.counts.docs);
      $('sysCntStaff').textContent = fmt(s.counts.staff);
      $('sysCntSess').textContent = fmt(s.counts.sessions);
    }

    var pill = $('sysUpdaterPill');
    pill.textContent = s.updater.installed ? 'updater online' : 'updater offline';
    pill.className = 'sys-updater-pill ' + (s.updater.installed ? 'is-on' : 'is-off');
    $('sysUpdaterMissing').hidden = !!s.updater.installed;
    $('sysUpdateBtn').disabled = !s.updater.installed || s.updater.pending;

    var st = s.updater.status, box = $('sysUpdateState');
    if (s.updater.pending || (st && st.state === 'queued')) {
      box.className = 'sys-update-state is-run';
      box.innerHTML = '<span class="sys-spin"></span> Update queued — the host picks it up within a minute…';
    } else if (st && st.state === 'running') {
      box.className = 'sys-update-state is-run';
      box.innerHTML = '<span class="sys-spin"></span> ' + esc(st.detail || 'Updating…');
    } else if (st && st.state === 'ok') {
      box.className = 'sys-update-state is-ok';
      box.textContent = '✓ ' + (st.detail || 'Up to date');
    } else if (st && st.state === 'error') {
      box.className = 'sys-update-state is-err';
      box.textContent = '✗ ' + (st.detail || 'Update failed');
    } else { box.className = 'sys-update-state'; box.textContent = ''; }
    if (s.build && (s.build.commit || s.build.version)) $('sysBuild').textContent = s.build.commit || ('v' + s.build.version);
    if (window.fillTimes) window.fillTimes();
  }
  function esc(x) { return String(x == null ? '' : x).replace(/[&<>]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]; }); }
  var liveEl = $('sysLive');
  function flashLive() { if (!liveEl) return; liveEl.classList.remove('beat'); void liveEl.offsetWidth; liveEl.classList.add('beat'); }

  function alive() { var e = $('sysCpu'); return !!e && document.body.contains(e); }
  function tick() {
    if (!alive()) return;
    fetch('/admin/system/stats', { cache: 'no-store' })
      .then(function (r) { return r.json(); })
      .then(function (d) { if (d.ok && alive()) { paint(d.stats); flashLive(); } })
      .catch(function () { /* the app may be restarting mid-update — keep polling */ });
  }
  paint(<%- JSON.stringify(stats) %>);
  // near-real-time: poll every 2s, and pause while the tab is hidden so we
  // don't spend the droplet's CPU on a screen nobody is looking at.
  var iv = null;
  function startPoll() { if (!iv) iv = setInterval(function () { if (alive()) tick(); }, 2000); }
  function stopPoll() { if (iv) { clearInterval(iv); iv = null; } }
  startPoll();
  function onVis() { if (document.hidden) stopPoll(); else { tick(); startPoll(); } }
  document.addEventListener('visibilitychange', onVis);
  if (window.pjaxRegister) window.pjaxRegister(function () { stopPoll(); document.removeEventListener('visibilitychange', onVis); });

  // Submitting the update form should not navigate — queue it via fetch.
  var form = $('sysUpdateForm');
  function run() {
    var btn = $('sysUpdateBtn'); btn.disabled = true;
    var box = $('sysUpdateState');
    box.className = 'sys-update-state is-run';
    box.innerHTML = '<span class="sys-spin"></span> Queueing…';
    fetch('/admin/system/update', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ _csrf: form.querySelector('[name=_csrf]').value }),
    }).then(function (r) { return r.json(); }).then(function (d) {
      if (!d.ok) { box.className = 'sys-update-state is-err'; box.textContent = '✗ ' + (d.error || 'Could not queue.'); btn.disabled = false; return; }
      tick();
    }).catch(function () { box.className = 'sys-update-state is-err'; box.textContent = '✗ Could not reach the server.'; btn.disabled = false; });
  }
  // "Reviewed" clears a withheld doc update from the list.
  var pend = document.querySelector('.sys-pending-list');
  if (pend) pend.addEventListener('click', function (e) {
    var b = e.target.closest('[data-dismiss]'); if (!b) return;
    var slug = b.getAttribute('data-dismiss');
    b.disabled = true;
    fetch('/admin/system/pending/dismiss', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ _csrf: form.querySelector('[name=_csrf]').value, slug: slug }),
    }).then(function (r) { return r.json(); }).then(function (d) {
      if (!d.ok) { b.disabled = false; return; }
      var li = b.closest('li'); li.remove();
      if (!pend.children.length) pend.closest('.sys-pending').remove();
    }).catch(function () { b.disabled = false; });
  });

  // NB: no data-confirm here — that helper calls form.submit(), which would
  // bypass this handler and hard-navigate. Confirm inline instead.
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    if (window.vcfConfirm) {
      window.vcfConfirm({
        title: 'Run update',
        message: 'Pull the latest code from main and rebuild on the host? The site restarts for a few seconds while the new build comes up.',
        okLabel: 'Update now', danger: false,
      }, run);
    } else if (confirm('Pull the latest code and rebuild?')) run();
  });
})();
</script>
  </main>
