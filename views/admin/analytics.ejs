<%- include('../partials/head') %>
<%- include('../partials/topbar') %>
<div class="layout">
  <%- include('../partials/admin-side') %>
  <main class="content admin-content">
    <div class="admin-titlerow">
      <div><h1 class="admin-h1">Analytics</h1><p class="admin-sub">Traffic to your documentation, counted <strong>per user</strong> — repeat visits to the same page in a day count once. IP + user-agent are hashed, never stored raw.</p></div>
      <div class="range-tabs">
        <% [7,30,90].forEach(function(d){ %><a class="range-tab <%= totals.days===d ? 'active':'' %>" href="/admin/analytics?days=<%= d %>"><%= d %>d</a><% }); %>
      </div>
    </div>

    <div class="stat-grid stat-grid-ico">
      <% [
        { n: totals.viewsToday, l: 'Views today', ic: 'chart' },
        { n: totals.viewsRange, l: 'Views · ' + totals.days + 'd', ic: 'files' },
        { n: totals.visitorsRange, l: 'Unique visitors · ' + totals.days + 'd', ic: 'users' },
        { n: totals.avgPerDay, l: 'Avg views / day', ic: 'chart' },
        { n: totals.busiestViews, l: 'Busiest day (' + totals.busiestDay.slice(5) + ')', ic: 'calendar' },
        { n: totals.views, l: 'All-time views', ic: 'eye' }
      ].forEach(function (s) { %>
        <div class="stat-card"><span class="stat-ico"><%- icon(s.ic) %></span><span class="stat-num"><%= s.n %></span><span class="stat-label"><%= s.l %></span></div>
      <% }); %>
    </div>

    <section class="panel globe-panel">
      <div class="panel-head"><h2><%- icon('external') %> Where your traffic comes from</h2><span class="muted small"><%= countryTotal %> located visitor<%= countryTotal===1?'':'s' %> · <%= totals.days %>d</span></div>
      <div class="globe-layout">
        <div class="globe-stage"><canvas id="trafficGlobe" width="380" height="380" aria-label="Rotating globe of traffic origin"></canvas></div>
        <div class="globe-side">
          <div class="globe-side-h">Top countries</div>
          <ul class="globe-list" id="globeList"><li class="muted small">Loading…</li></ul>
        </div>
      </div>
    </section>

    <section class="panel live-panel" id="livePanel">
      <div class="panel-head"><h2><span class="live-dot"></span> Live &mdash; last 5 minutes</h2><span class="muted small" id="liveClock"></span></div>
      <div class="live-grid">
        <div class="live-stat"><span class="live-num" id="liveActive">–</span><span class="stat-label">Active visitors</span></div>
        <div class="live-stat"><span class="live-num" id="liveStaff">–</span><span class="stat-label">Staff online</span></div>
        <div class="live-spark"><svg id="liveSpark" viewBox="0 0 300 48" preserveAspectRatio="none"></svg><span class="stat-label">Views · last 30 min</span></div>
      </div>
      <div class="live-body">
        <div class="live-col"><div class="live-h">Online now</div><ul class="live-online" id="liveOnline"><li class="muted">—</li></ul></div>
        <div class="live-col"><div class="live-h">Live feed</div><ul class="live-feed" id="liveFeed"><li class="muted">Connecting…</li></ul></div>
      </div>
    </section>

    <section class="panel">
      <div class="panel-head"><h2>Views &amp; visitors per day</h2><span class="muted small"><span class="legend-dot dot-views"></span> Views &nbsp; <span class="legend-dot dot-visitors"></span> Visitors</span></div>
      <%
        var W=760,H=240,padL=32,padB=22,padT=12,padR=8;
        var maxV=1; series.forEach(function(s){ if(s.views>maxV)maxV=s.views; });
        var n=series.length, xstep=(W-padL-padR)/Math.max(1,n-1), yScale=(H-padT-padB)/maxV;
        function X(i){return padL+i*xstep;} function Y(v){return H-padB-v*yScale;}
        var line=series.map(function(s,i){return (i===0?'M':'L')+X(i).toFixed(1)+' '+Y(s.views).toFixed(1);}).join(' ');
        var vline=series.map(function(s,i){return (i===0?'M':'L')+X(i).toFixed(1)+' '+Y(s.visitors).toFixed(1);}).join(' ');
        var area='M'+X(0).toFixed(1)+' '+(H-padB)+' '+series.map(function(s,i){return 'L'+X(i).toFixed(1)+' '+Y(s.views).toFixed(1);}).join(' ')+' L'+X(n-1).toFixed(1)+' '+(H-padB)+' Z';
      %>
      <div class="chart-wrap">
        <svg class="chart" viewBox="0 0 <%= W %> <%= H %>" preserveAspectRatio="none" role="img" aria-label="Views per day">
          <defs><linearGradient id="chartFill" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#ffa200" stop-opacity="0.28"/><stop offset="100%" stop-color="#ffa200" stop-opacity="0"/></linearGradient></defs>
          <% for(var g=0;g<=4;g++){ var gy=padT+(H-padT-padB)*g/4; %>
            <line class="grid" x1="<%= padL %>" y1="<%= gy.toFixed(1) %>" x2="<%= W-padR %>" y2="<%= gy.toFixed(1) %>"/>
            <text class="axis" x="0" y="<%= (gy+4).toFixed(1) %>"><%= Math.round(maxV*(4-g)/4) %></text>
          <% } %>
          <path class="area" d="<%= area %>"/>
          <path class="spark" d="<%= line %>"/>
          <path class="spark2" d="<%= vline %>"/>
        </svg>
        <div class="chart-x"><span><%= series[0].day.slice(5) %></span><span><%= series[Math.floor(n/2)].day.slice(5) %></span><span><%= series[n-1].day.slice(5) %></span></div>
      </div>
    </section>

    <div class="admin-cols">
      <section class="panel">
        <div class="panel-head"><h2>Top pages · <%= totals.days %>d</h2></div>
        <% if(!topPages.length){ %><p class="muted">No page views recorded yet.</p><% } else { var tmax=topPages[0].views; %>
          <table class="table"><thead><tr><th>Page</th><th class="num">Unique viewers</th></tr></thead><tbody>
            <% topPages.forEach(function(p){ %>
              <tr><td><a href="/<%= p.slug %>" target="_blank"><% if(p.internal){ %><span class="ic ic-lock"></span> <% } %><%= p.title %></a>
                <div class="bar"><span style="width: <%= Math.round(p.views/tmax*100) %>%"></span></div></td>
                <td class="num"><%= p.views %></td></tr>
            <% }); %>
          </tbody></table>
        <% } %>
      </section>

      <section class="panel">
        <div class="panel-head"><h2>Referrers · <%= totals.days %>d</h2></div>
        <% if(!referrers.length){ %><p class="muted">No external referrers recorded.</p><% } else { %>
          <table class="table"><thead><tr><th>Source</th><th class="num">Hits</th></tr></thead><tbody>
            <% referrers.forEach(function(r){ %><tr><td class="mono ellipsis"><%= r.referrer %></td><td class="num"><%= r.n %></td></tr><% }); %>
          </tbody></table>
        <% } %>
      </section>
    </div>

    <div class="admin-cols cols-3">
      <%
        function barList(items){ var tot=items.reduce(function(a,b){return a+b.n;},0)||1; return { items: items, tot: tot }; }
        var audienceItems=[{label:'Staff (logged in)',n:authed.staff},{label:'Anonymous',n:authed.anon}];
        var scopeItems=[{label:'Public pages',n:scope.public},{label:'Internal handbooks',n:scope.internal}];
      %>
      <section class="panel"><div class="panel-head"><h2>Audience</h2></div><%- include('../partials/barlist', { data: audienceItems }) %></section>
      <section class="panel"><div class="panel-head"><h2>Content scope</h2></div><%- include('../partials/barlist', { data: scopeItems }) %></section>
      <section class="panel"><div class="panel-head"><h2>Browsers</h2></div><%- include('../partials/barlist', { data: browsers }) %></section>
    </div>

    <div class="admin-cols">
      <section class="panel">
        <div class="panel-head"><h2>Views by hour (UTC)</h2></div>
        <% var hmax=1; byHour.forEach(function(h){ if(h.n>hmax)hmax=h.n; }); %>
        <div class="hour-chart">
          <% byHour.forEach(function(h){ %><div class="hour-bar" data-tip="<%= h.h %>:00 — <%= h.n %> views" data-tip-pos="top"><span style="height: <%= Math.round(h.n/hmax*100) %>%"></span></div><% }); %>
        </div>
        <div class="hour-axis"><span>00</span><span>06</span><span>12</span><span>18</span><span>23</span></div>
      </section>
      <section class="panel"><div class="panel-head"><h2>Operating systems</h2></div><%- include('../partials/barlist', { data: oses }) %></section>
    </div>

    <section class="panel">
      <div class="panel-head"><h2>Recent activity</h2></div>
      <% if(!recent.length){ %><p class="muted">No recent views.</p><% } else { %>
        <table class="table"><thead><tr><th>Page</th><th>Visitor</th><th>When</th></tr></thead><tbody>
          <% recent.forEach(function(r){ %><tr><td><a href="/<%= r.slug %>" target="_blank"><%= r.title %></a></td>
            <td><span class="badge <%= r.authed ? 'badge-internal':'' %>"><%= r.username || (r.authed ? 'Staff':'Anon') %></span></td>
            <td class="muted small"><time data-time="<%= r.ts %>"><%= r.ts %></time></td></tr><% }); %>
        </tbody></table>
      <% } %>
    </section>

    <p class="muted small">No third-party trackers are used. All metrics are computed from first-party server logs.</p>
<script>
(function () {
  var esc = function (s) { return String(s == null ? '' : s).replace(/[<>&]/g, function (c) { return { '<': '&lt;', '>': '&gt;', '&': '&amp;' }[c]; }); };
  function ago(t) { var s = Math.max(0, (Date.now() - new Date(t.replace(' ', 'T') + 'Z')) / 1000); if (s < 60) return Math.floor(s) + 's'; if (s < 3600) return Math.floor(s / 60) + 'm'; return Math.floor(s / 3600) + 'h'; }
  function spark(pts) {
    if (!pts.length) return '';
    var max = 1; pts.forEach(function (p) { if (p.n > max) max = p.n; });
    var n = pts.length, dx = 300 / Math.max(1, n - 1);
    var d = pts.map(function (p, i) { return (i ? 'L' : 'M') + (i * dx).toFixed(1) + ' ' + (46 - p.n / max * 44).toFixed(1); }).join(' ');
    return '<path d="' + d + '" fill="none" stroke="#ffa200" stroke-width="2" stroke-linejoin="round"/>';
  }
  function tick() {
    fetch('/api/analytics/live', { cache: 'no-store' }).then(function (r) { return r.json(); }).then(function (d) {
      if (!d.ok) return;
      document.getElementById('liveActive').textContent = d.active;
      document.getElementById('liveStaff').textContent = d.activeStaff;
      document.getElementById('liveSpark').innerHTML = spark(d.perMin || []);
      document.getElementById('liveClock').textContent = 'updated ' + new Date().toLocaleTimeString();
      document.getElementById('liveOnline').innerHTML = (d.onlineNow && d.onlineNow.length)
        ? d.onlineNow.map(function (o) { return '<li><span class="acct-avatar sm">' + esc(o.username[0].toUpperCase()) + '</span>' + esc(o.username) + ' <span class="muted">' + ago(o.ts) + '</span></li>'; }).join('')
        : '<li class="muted">No staff online</li>';
      document.getElementById('liveFeed').innerHTML = (d.recent && d.recent.length)
        ? d.recent.map(function (r) { return '<li><span class="muted mono">' + ago(r.ts) + '</span> <strong>' + esc(r.who) + '</strong> → ' + esc(r.title || r.slug) + '</li>'; }).join('')
        : '<li class="muted">No recent views</li>';
    }).catch(function () {});
  }
  function onVis() { if (!document.hidden) tick(); }
  function liveOn() { var el = document.getElementById('liveActive'); return !!el && document.body.contains(el); }
  tick(); var iv = setInterval(function () { if (liveOn()) tick(); }, 5000);
  document.addEventListener('visibilitychange', onVis);
  if (window.pjaxRegister) window.pjaxRegister(function () { clearInterval(iv); document.removeEventListener('visibilitychange', onVis); });
})();
</script>
<script>window.GLOBE_DATA = <%- JSON.stringify(countries || []) %>;</script>
<script src="/assets/js/globe.js?v=<%= assetVersion %>"></script>
  </main>
</div>
<%- include('../partials/foot') %>
