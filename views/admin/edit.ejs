<%- include('../partials/head') %>
<div class="editor-shell"
     data-csrf="<%= csrfToken %>"
     data-new="<%= isNew ? '1' : '0' %>"
     data-original-slug="<%= page.slug %>"
     data-user="<%= user.username %>"
     data-icons="<%= (iconNames || []).join(',') %>">
  <div class="editor-bar">
    <div class="editor-bar-left">
      <a class="btn btn-ghost btn-sm" href="/admin/pages">← Pages</a>
      <span class="editor-title"><%= isNew ? 'New page' : 'Editing: ' + page.title %></span>
      <span class="save-state" id="saveState"></span>
      <span class="collab-chips" id="collabChips"></span>
    </div>
    <div class="editor-bar-right">
      <div class="mode-tabs" id="modeTabs">
        <button type="button" data-mode="wysiwyg" class="active">Editor</button>
        <button type="button" data-mode="markdown">Markdown</button>
        <button type="button" data-mode="preview">Preview</button>
      </div>
      <button class="btn btn-ghost btn-sm" type="button" id="settingsToggle" data-tip-pos="bottom" data-tip="Page settings"><%- icon('gear') %> Settings</button>
      <% if (!isNew) { %><a class="btn btn-ghost btn-sm" href="/<%= page.slug %>" target="_blank">View live ↗</a><% } %>
      <% if (!isNew && !(typeof undeletable !== 'undefined' && undeletable)) { %><button class="btn btn-ghost btn-sm danger" type="button" id="deleteBtn">Delete</button><% } %>
      <button class="btn btn-solid btn-sm" type="button" id="saveBtn">Save changes</button>
    </div>
  </div>

  <div class="editor-main has-settings-side" id="editorMain">
    <div class="editor-surface">
      <!-- WYSIWYG -->
      <div class="wysiwyg-wrap" id="wzPane">
        <div class="wz-toolbar" id="wzToolbar">
          <button class="wz-btn" data-cmd="undo" data-tip-pos="bottom" data-tip="Undo (Ctrl+Z)" id="undoBtn">↺</button>
          <button class="wz-btn" data-cmd="redo" data-tip-pos="bottom" data-tip="Redo (Ctrl+Shift+Z)" id="redoBtn">↻</button>
          <span class="sep"></span>
          <button class="wz-btn" data-cmd="h2" data-tip-pos="bottom" data-tip="Heading">H2</button>
          <button class="wz-btn" data-cmd="h3" data-tip-pos="bottom" data-tip="Subheading">H3</button>
          <span class="sep"></span>
          <button class="wz-btn" data-cmd="bold" data-tip-pos="bottom" data-tip="Bold (Ctrl+B)"><%- icon('bold') %></button>
          <button class="wz-btn" data-cmd="italic" data-tip-pos="bottom" data-tip="Italic (Ctrl+I)"><%- icon('italic') %></button>
          <button class="wz-btn" data-cmd="strike" data-tip-pos="bottom" data-tip="Strikethrough"><%- icon('strike') %></button>
          <button class="wz-btn" data-cmd="code" data-tip-pos="bottom" data-tip="Inline code"><%- icon('code') %></button>
          <button class="wz-btn" data-cmd="link" data-tip-pos="bottom" data-tip="Link (Ctrl+K)"><%- icon('link') %></button>
          <button class="wz-btn" data-cmd="icon" data-tip-pos="bottom" data-tip="Insert icon"><%- icon('star') %></button>
          <span class="sep"></span>
          <button class="wz-btn" data-cmd="ul" data-tip-pos="bottom" data-tip="Bulleted list"><%- icon('list') %></button>
          <button class="wz-btn" data-cmd="ol" data-tip-pos="bottom" data-tip="Numbered list">1.</button>
          <button class="wz-btn" data-cmd="quote" data-tip-pos="bottom" data-tip="Quote"><%- icon('quote') %></button>
          <button class="wz-btn" data-cmd="hr" data-tip-pos="bottom" data-tip="Divider"><%- icon('divider') %></button>
          <span class="sep"></span>
          <button class="wz-btn" data-cmd="insert" data-tip-pos="bottom" data-tip="Insert block"><%- icon('plus') %> Insert</button>
        </div>
        <div class="wz-editor markdown" id="wzEditor"></div>
      </div>

      <!-- Markdown -->
      <div class="wysiwyg-wrap" id="mdPane" hidden>
        <textarea id="md" spellcheck="true"><%= page.content %></textarea>
        <div class="md-hint">Markdown + callouts <code>:::note</code> … <code>:::</code>, accordions <code>:::details Title</code>, and icons <code>:i[shield]:</code>.</div>
      </div>

      <!-- Preview -->
      <div class="wysiwyg-wrap" id="previewPane" hidden>
        <article class="doc"><div class="markdown" id="preview"></div></article>
      </div>
    </div>

    <!-- Collapsible page-settings sidebar -->
    <aside class="settings-side" id="settingsSide">
      <div class="settings-side-head"><span><%- icon('gear') %> Page settings</span><button class="btn btn-ghost btn-sm" type="button" id="settingsClose" aria-label="Close settings"><%- icon('x') %></button></div>
      <div class="settings-stack">
        <label class="setting">Title <input type="text" id="f-title" value="<%= page.title %>" /></label>
        <label class="setting">URL slug <input type="text" id="f-slug" value="<%= page.slug %>" placeholder="section/page-name" /></label>
        <label class="setting">Group <input type="text" id="f-group" list="group-list" value="<%= page.group_name %>" placeholder="e.g. Shifts" />
          <datalist id="group-list"><% groups.forEach(function (g) { %><option value="<%= g %>"></option><% }); %></datalist>
        </label>
        <div class="setting">Icon
          <div class="icon-pick-row">
            <button type="button" class="icon-pick-btn" id="iconPickBtn"><span class="icon-pick-preview" id="iconPickPreview"><% if (page.icon) { %><%- icon(page.icon) %><% } %></span><span id="iconPickLabel"><%= page.icon || 'Choose icon…' %></span></button>
            <input type="hidden" id="f-icon" value="<%= page.icon %>" />
          </div>
        </div>
        <label class="setting">Sort order <input type="number" id="f-sort" value="<%= page.sort %>" /></label>
        <label class="setting">Description <input type="text" id="f-desc" value="<%= page.description %>" placeholder="Shown as the page subtitle and in search & social embeds" /></label>
        <div class="setting setting-toggle">
          <label class="switch"><input type="checkbox" id="f-internal" <%= page.internal ? 'checked' : '' %> /><span class="switch-track"></span></label>
          <span class="setting-toggle-label">Internal <small>staff only</small></span>
        </div>
        <label class="setting" id="divisionField">Division access
          <select id="f-division">
            <option value="">— Not restricted</option>
            <option value="all" <%= page.division === 'all' ? 'selected' : '' %>>All staff</option>
            <option value="management" <%= page.division === 'management' ? 'selected' : '' %>>Management</option>
            <option value="moderation" <%= page.division === 'moderation' ? 'selected' : '' %>>Moderation</option>
            <option value="sid" <%= page.division === 'sid' ? 'selected' : '' %>>Specialized Investigations</option>
            <option value="osc" <%= page.division === 'osc' ? 'selected' : '' %>>Oversight Committee</option>
          </select>
        </label>
      </div>
    </aside>
  </div>

  <% if (!isNew && revisions.length) { %>
  <details class="rev-drawer">
    <summary>Revision history (<%= revisions.length %>)</summary>
    <ul class="rev-list">
      <% revisions.forEach(function (r) { %>
        <li><span class="muted mono">#<%= r.id %></span> <%= r.created_at %> · <%= r.editor %>
          <button class="btn btn-ghost btn-sm restore-btn" data-id="<%= r.id %>" type="button">Restore</button></li>
      <% }); %>
    </ul>
  </details>
  <% } %>
</div>
<script src="/assets/vendor/y.js?v=<%= assetVersion %>"></script>
<script src="/assets/js/editor.js?v=<%= assetVersion %>"></script>
<%- include('../partials/foot') %>
