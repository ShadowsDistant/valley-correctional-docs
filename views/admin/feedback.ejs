<%- include('../partials/head') %>
<%- include('../partials/topbar') %>
<%
  var CATS = { idea: { label: 'Idea', ic: 'lightbulb' }, bug: { label: 'Bug', ic: 'bug' }, improvement: { label: 'Improvement', ic: 'star' }, other: { label: 'Other', ic: 'message' } };
  function catMeta(c) { return CATS[c] || CATS.other; }
  function searchText(f) { return ((f.title || '') + ' ' + (f.body || '') + ' ' + (f.submitted_by || '') + ' ' + (f.roblox_user || '')).toLowerCase(); }
%>
<div class="layout">
  <% if (canEdit) { %><%- include('../partials/admin-side') %><% } %>
  <main class="content admin-content <%= canEdit ? '' : 'admin-content-wide' %>">
    <div class="admin-titlerow">
      <div>
        <h1 class="admin-h1">Community Feedback</h1>
        <p class="admin-sub">Ideas and reports from the community. Approve what ships, reject what won't, and chat with submitters — they see your replies on their feedback page.</p>
      </div>
      <% if (counts.needsReply) { %><span class="badge badge-danger fb-needs-badge"><%- icon('message') %> <%= counts.needsReply %> awaiting reply</span><% } %>
    </div>

    <div class="fb-admin-toolbar">
      <div class="dash-tabs staff-tabs fb-status-tabs" id="fbStatusTabs">
        <button type="button" class="dash-tab" data-status="">All <span class="tab-count"><%= counts.all %></span></button>
        <button type="button" class="dash-tab" data-status="open">Open <% if (counts.open) { %><span class="tab-count"><%= counts.open %></span><% } %></button>
        <button type="button" class="dash-tab" data-status="approved">Approved <span class="tab-count"><%= counts.approved %></span></button>
        <button type="button" class="dash-tab" data-status="rejected">Rejected <span class="tab-count"><%= counts.rejected %></span></button>
      </div>
      <div class="fb-search">
        <%- icon('search') %>
        <input type="text" id="fbSearch" value="<%= q %>" placeholder="Search feedback…" autocomplete="off" />
        <button type="button" class="fb-search-clear" id="fbSearchClear" aria-label="Clear search" hidden><%- icon('x') %></button>
      </div>
    </div>

    <div class="fb-cat-filters" id="fbCatFilters">
      <button type="button" class="fb-cat-filter" data-category="">All types</button>
      <% categories.forEach(function (c) { var m = catMeta(c); %>
        <button type="button" class="fb-cat-filter" data-category="<%= c %>"><span class="ic ic-<%= m.ic %>"></span> <%= m.label %></button>
      <% }); %>
      <span class="fb-shown-count muted small" id="fbShownCount"></span>
    </div>

    <div id="fbList">
      <% items.forEach(function (f) { var m = catMeta(f.category); var needsReply = f.last_sender === 'submitter'; %>
        <section class="panel fb-card <%= needsReply ? 'fb-card-flag' : '' %>" data-id="<%= f.id %>" data-status="<%= f.status %>" data-category="<%= f.category %>" data-text="<%= searchText(f) %>">
          <div class="fb-card-head">
            <span class="fb-card-avatar" <% if (f.roblox_user) { %>data-rbx-avatar="<%= f.roblox_user %>"<% } %> style="--h:<%= (f.submitted_by || f.roblox_user || 'anon').split('').reduce(function(a,c){return (a*31+c.charCodeAt(0))%360;},0) %>"><%= (f.submitted_by || f.roblox_user || '?').slice(0,1).toUpperCase() %></span>
            <div class="fb-card-headmain">
              <div class="fb-card-tags">
                <span class="fb-cat-chip cat-<%= f.category %>"><span class="ic ic-<%= m.ic %>"></span><%= m.label %></span>
                <span class="pill pill-<%= f.status==='open'?'amber':(f.status==='rejected'?'red':'green') %>" data-statuspill><%= f.status %></span>
                <% if (needsReply) { %><span class="fb-flag" data-flag><%- icon('message') %> Awaiting reply</span><% } %>
              </div>
              <% if (f.status_reason) { %><div class="fb-status-reason muted small"><strong><%= f.status %>:</strong> <%= f.status_reason %></div><% } %>
              <div class="fb-card-title"><%= f.title %></div>
              <div class="muted small fb-card-by">
                by <strong><%= f.submitted_by || 'anonymous' %></strong><% if (f.roblox_user) { %> · Roblox <strong><%= f.roblox_user %></strong><% } %>
                · <time data-time="<%= f.created_at %>"><%= f.created_at.slice(0,16) %></time>
                · <%= f.msgs %> message<%= f.msgs===1?'':'s' %>
                <% if (f.status !== 'open' && f.status_by) { %> · <%= f.status %> by <%= f.status_by %><% } %>
              </div>
            </div>
            <div class="fb-card-actions">
              <% ['approved','rejected','open'].forEach(function (s) { if (f.status !== s) { %>
                <form method="post" action="/admin/feedback/status" class="inline"<% if (s !== 'open') { %> data-confirm="<%= s==='approved' ? 'Approve this feedback? Your reason is shared with the submitter.' : 'Reject this feedback? Your reason is shared with the submitter.' %>" data-confirm-title="<%= s==='approved' ? 'Approve feedback' : 'Reject feedback' %>" data-confirm-ok="<%= s==='approved' ? 'Approve' : 'Reject' %>" data-confirm-variant="<%= s==='rejected' ? '' : 'safe' %>" data-confirm-input="Reason (shared with the submitter)"<% } %>>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" /><input type="hidden" name="id" value="<%= f.id %>" /><input type="hidden" name="status" value="<%= s %>" />
                  <button class="btn btn-ghost btn-sm <%= s==='rejected'?'danger':(s==='approved'?'ok':'') %>" type="submit"><%= s==='open' ? 'Reopen' : (s==='approved' ? 'Approve' : 'Reject') %></button>
                </form>
              <% } }); %>
              <button class="btn btn-ghost btn-sm fb-chat-btn" type="button" data-thread="<%= f.id %>"><%- icon('message') %> Chat<% if (f.msgs) { %> <span class="tab-count"><%= f.msgs %></span><% } %></button>
            </div>
          </div>
          <p class="fb-card-body"><%= f.body %></p>
          <div class="fb-thread-inline" id="thread-<%= f.id %>" hidden>
            <div class="fb-chat fb-chat-inline" data-msgs></div>
            <form class="fb-composer fb-composer-inline" data-reply="<%= f.id %>">
              <textarea class="fb-composer-input" rows="1" maxlength="2000" placeholder="Reply to the submitter…"></textarea>
              <button class="btn btn-solid fb-send" type="submit" aria-label="Send"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7Z"/></svg></button>
            </form>
            <div class="auth-error fb-composer-error" data-err hidden><%- icon('danger') %> <span></span></div>
          </div>
        </section>
      <% }); %>
    </div>
    <div class="fb-empty" id="fbEmpty" hidden><span class="ic ic-message"></span><p>No feedback matches your filters.</p></div>
<script>
(function () {
  function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]; }); }
  function initial(name) { return (name || '?').trim().charAt(0).toUpperCase() || '?'; }
  function hueOf(name) { var h = 0; for (var i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) % 360; return h; }
  function avatar(name, staff) { return '<span class="fb-av' + (staff ? ' is-staff' : '') + '" style="--h:' + hueOf(name || 'anon') + '">' + esc(initial(name)) + '</span>'; }

  // ---------- instant client-side filtering (no reload) ----------
  var curStatus = <%- JSON.stringify(status || '') %>, curCat = <%- JSON.stringify(category || '') %>, curQ = <%- JSON.stringify((q || '').toLowerCase()) %>;
  var statusTabs = document.getElementById('fbStatusTabs');
  var catFilters = document.getElementById('fbCatFilters');
  var searchInput = document.getElementById('fbSearch');
  var searchClear = document.getElementById('fbSearchClear');
  var shownCount = document.getElementById('fbShownCount');
  var empty = document.getElementById('fbEmpty');
  var cards = Array.prototype.slice.call(document.querySelectorAll('#fbList .fb-card'));

  function markActive(container, attr, val) {
    container.querySelectorAll('[' + attr + ']').forEach(function (b) { b.classList.toggle('active', b.getAttribute(attr) === val); });
  }
  function apply() {
    var shown = 0;
    cards.forEach(function (c) {
      var ok = (!curStatus || c.getAttribute('data-status') === curStatus)
        && (!curCat || c.getAttribute('data-category') === curCat)
        && (!curQ || (c.getAttribute('data-text') || '').indexOf(curQ) !== -1);
      c.hidden = !ok; if (ok) shown++;
    });
    empty.hidden = shown > 0;
    shownCount.textContent = shown + (shown === 1 ? ' item' : ' items');
    searchClear.hidden = !curQ;
    markActive(statusTabs, 'data-status', curStatus);
    markActive(catFilters, 'data-category', curCat);
    // keep the URL in sync (shareable) without reloading
    var p = new URLSearchParams();
    if (curStatus) p.set('status', curStatus);
    if (curCat) p.set('category', curCat);
    if (curQ) p.set('q', searchInput.value.trim());
    history.replaceState({ pjax: 1 }, '', '/admin/feedback' + (p.toString() ? '?' + p.toString() : ''));
  }
  statusTabs.addEventListener('click', function (e) { var b = e.target.closest('[data-status]'); if (b) { curStatus = b.getAttribute('data-status'); apply(); } });
  catFilters.addEventListener('click', function (e) { var b = e.target.closest('[data-category]'); if (b) { curCat = b.getAttribute('data-category'); apply(); } });
  var st;
  searchInput.addEventListener('input', function () { clearTimeout(st); st = setTimeout(function () { curQ = searchInput.value.trim().toLowerCase(); apply(); }, 120); });
  searchClear.addEventListener('click', function () { searchInput.value = ''; curQ = ''; apply(); searchInput.focus(); });
  apply();

  // ---------- chat ----------
  var polls = {}, sigs = {};
  function chatSig(id, d) { return id + '|' + d.feedback.status + '|' + d.messages.map(function (m) { return m.created_at + m.sender + m.body + (m.deleted ? 'D' : ''); }).join('~'); }
  function renderChat(box, d) {
    var msgs = [{ sender: 'submitter', body: d.feedback.body, created_at: d.feedback.created_at, _first: true, sender_name: d.feedback.submitted_by || 'Submitter' }].concat(d.messages);
    var html = '', lastDay = '', prevSender = null;
    msgs.forEach(function (m) {
      var day = (m.created_at || '').slice(0, 10);
      if (day && day !== lastDay) { html += '<div class="fb-day"><span>' + esc(day) + '</span></div>'; lastDay = day; prevSender = null; }
      var mine = m.sender === 'staff';
      var name = mine ? (m.sender_name || 'You') : (m.sender_name || 'Submitter');
      var grouped = m.sender === prevSender && !m._first;
      html += '<div class="fb-bubble-row ' + (mine ? 'mine' : 'theirs') + (grouped ? ' grouped' : '') + (m.deleted ? ' is-deleted' : '') + '">';
      html += grouped ? '<span class="fb-av-spacer"></span>' : avatar(name, mine);
      html += '<div class="fb-bubble-col">';
      if (!grouped) html += '<div class="fb-bubble-name">' + esc(name) + (mine ? ' <span class="fb-staff-tag">Staff</span>' : '') + '</div>';
      html += '<div class="fb-bubble">' + (m.deleted ? '<span class="fb-deleted-tag">deleted' + (m.deleted_by ? ' by ' + esc(m.deleted_by) : '') + '</span> ' : '') + esc(m.body) + '</div>';
      html += '<div class="fb-bubble-time muted"><time data-time="' + esc(m.created_at) + '">' + esc((m.created_at || '').slice(0, 16)) + '</time>'
        + (!m._first && !m.deleted && m.id ? ' · <button type="button" class="fb-msg-del" data-msgdel="' + m.id + '">delete</button>' : '') + '</div>';
      html += '</div></div>';
      prevSender = m.sender;
    });
    box.innerHTML = html;
    if (window.fillTimes) window.fillTimes();
  }
  function loadThread(id, scroll) {
    var wrap = document.getElementById('thread-' + id); if (!wrap) return;
    var box = wrap.querySelector('[data-msgs]');
    var atBottom = box.scrollHeight - box.scrollTop - box.clientHeight < 60;
    return fetch('/api/feedback/' + id + '/messages').then(function (r) { return r.json(); }).then(function (d) {
      if (!d.ok) return;
      var sig = chatSig(id, d);
      if (sig === sigs[id] && !scroll) return;
      sigs[id] = sig;
      renderChat(box, d);
      // clear the "awaiting reply" flag on this card once staff have opened & the last message is staff
      var card = document.querySelector('.fb-card[data-id="' + id + '"]');
      if (card && d.messages.length && d.messages[d.messages.length - 1].sender === 'staff') {
        card.classList.remove('fb-card-flag');
        var fl = card.querySelector('[data-flag]'); if (fl) fl.remove();
      }
      if (scroll || atBottom) box.scrollTop = box.scrollHeight;
    }).catch(function () {});
  }
  // delete a chat message (kept, shown struck to staff)
  function onMsgDel(e) {
    var d = e.target.closest('[data-msgdel]'); if (!d) return;
    var msgId = d.getAttribute('data-msgdel');
    var threadId = d.closest('.fb-thread-inline').id.replace('thread-', '');
    if (window.vcfConfirm) window.vcfConfirm({ title: 'Delete message', message: 'Delete this message? It stays visible to staff but is hidden from the submitter.', okLabel: 'Delete' }, doDel);
    else if (confirm('Delete this message?')) doDel();
    function doDel() {
      fetch('/api/feedback/message/' + msgId + '/delete', { method: 'POST' }).then(function (r) { return r.json(); }).then(function (res) {
        if (res.ok) { sigs[threadId] = ''; loadThread(threadId, false); }
      }).catch(function () {});
    }
  }
  function onThreadToggle(e) {
    var b = e.target.closest('[data-thread]'); if (!b) return;
    var id = b.getAttribute('data-thread');
    var wrap = document.getElementById('thread-' + id);
    wrap.hidden = !wrap.hidden;
    b.classList.toggle('active', !wrap.hidden);
    if (!wrap.hidden) {
      loadThread(id, true);
      clearInterval(polls[id]); polls[id] = setInterval(function () { loadThread(id); }, 8000);
      var ta = wrap.querySelector('textarea'); if (ta) setTimeout(function () { ta.focus(); }, 50);
    } else { clearInterval(polls[id]); }
  }
  function onComposerInput(e) {
    var ta = e.target.closest('.fb-composer-input'); if (!ta) return;
    ta.style.height = 'auto'; ta.style.height = Math.min(ta.scrollHeight, 120) + 'px';
  }
  function onComposerKey(e) {
    var ta = e.target.closest('.fb-composer-input'); if (!ta) return;
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); ta.closest('form').requestSubmit(); }
  }
  function onReplySubmit(e) {
    var form = e.target.closest('[data-reply]'); if (!form) return;
    e.preventDefault();
    var id = form.getAttribute('data-reply');
    var ta = form.querySelector('textarea');
    var err = form.parentNode.querySelector('[data-err]');
    err.hidden = true;
    var body = ta.value.trim(); if (!body) return;
    ta.disabled = true;
    fetch('/api/feedback/' + id + '/message', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ body: body })
    }).then(function (r) { return r.json(); }).then(function (d) {
      ta.disabled = false;
      if (!d.ok) { err.querySelector('span').textContent = d.error || 'Could not send.'; err.hidden = false; ta.focus(); return; }
      ta.value = ''; ta.style.height = 'auto'; ta.focus();
      loadThread(id, true);
    }).catch(function () { ta.disabled = false; err.querySelector('span').textContent = 'Could not send — try again.'; err.hidden = false; });
  }
  document.addEventListener('click', onMsgDel);
  document.addEventListener('click', onThreadToggle);
  document.addEventListener('input', onComposerInput);
  document.addEventListener('keydown', onComposerKey);
  document.addEventListener('submit', onReplySubmit);
  // tear down on client-side navigation so listeners/pollers don't pile up
  if (window.pjaxRegister) window.pjaxRegister(function () {
    document.removeEventListener('click', onMsgDel);
    document.removeEventListener('click', onThreadToggle);
    document.removeEventListener('input', onComposerInput);
    document.removeEventListener('keydown', onComposerKey);
    document.removeEventListener('submit', onReplySubmit);
    Object.keys(polls).forEach(function (id) { clearInterval(polls[id]); });
  });
})();
</script>
  </main>
</div>
<%- include('../partials/foot') %>
