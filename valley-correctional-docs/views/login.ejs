<%- include('partials/head') %>
<div class="auth-wrap">
  <div class="auth-card">
    <a class="auth-brand" href="/home">
      <span class="brand-mark">VCF</span>
      <span class="brand-title"><%= siteName %></span>
    </a>
    <h1>Staff Login</h1>
    <p class="auth-sub">Sign in to edit documentation, view analytics, and read internal handbooks.</p>
    <% if (error) { %><div class="auth-error"><%= error %></div><% } %>
    <form method="post" action="/login" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="next" value="<%= next %>" />
      <label>Username
        <input type="text" name="username" autocomplete="username" required autofocus />
      </label>
      <label>Password
        <input type="password" name="password" autocomplete="current-password" required />
      </label>
      <button class="btn btn-solid btn-block" type="submit">Log in</button>
    </form>
    <a class="auth-back" href="/home">← Back to documentation</a>
  </div>
</div>
<%- include('partials/foot') %>
