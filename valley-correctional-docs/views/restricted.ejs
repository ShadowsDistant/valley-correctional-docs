<%- include('partials/head') %>
<%- include('partials/topbar') %>
<div class="layout">
  <%- include('partials/sidebar') %>
  <main class="content">
    <article class="doc">
      <div class="doc-breadcrumb"><span><%= page.group_name %></span><span class="sep">/</span><span class="crumb-current"><%= page.title %></span></div>
      <div class="restricted-box">
        <div class="restricted-ico"><%- icon('lock') %></div>
        <% if (loggedIn) { %>
          <h1>Restricted to another division</h1>
          <p><strong><%= page.title %></strong> is limited to staff assigned to its division. Your account doesn't have access to this handbook.</p>
          <p class="muted small">If you believe you should have access, ask an administrator to add the relevant division to your account.</p>
          <a class="btn btn-primary" href="/home">Back to documentation</a>
        <% } else { %>
          <h1>Staff only</h1>
          <p><strong><%= page.title %></strong> is an internal document restricted to logged-in Valley Correctional Facility staff.</p>
          <a class="btn btn-solid" href="/login?next=<%= encodeURIComponent(nextUrl) %>">Log in to continue</a>
        <% } %>
      </div>
    </article>
  </main>
</div>
<%- include('partials/foot') %>
